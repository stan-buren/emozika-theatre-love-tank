---
interface Props {
  branches: {
    address: string;
    coords: number[];
    place: string;
  }[];
  center?: number[];
  zoom?: number;
}

const { branches, center = [59.9386, 30.3141], zoom = 10 } = Astro.props;
---

<div class="yandex-map-container">
    <img src="/images/map-placeholder.jpg" alt="Карта филиалов" style="width: 100%; height: 100%; object-fit: cover;" />
    <!-- 
    TODO: Enable interactive map when API Key is available.
    <div id="yandex-map" style="width: 100%; height: 100%;"></div>
    <script ... > ... </script> 
    -->
</div>

<style>
    .yandex-map-container {
        width: 100%;
        height: 500px; /* Fixed height to ensure visibility */
        min-height: 400px;
        background: #f0f0f0;
        border-radius: 12px;
        overflow: hidden;
    }
</style>
