---
interface Props {
  isLanding?: boolean;
}
const { isLanding = false } = Astro.props;
---
<header class="site-header">
    <div class="container header-inner">
      <div class="logo-container">
        <a href={import.meta.env.BASE_URL} class="logo-circle" data-scroll-to="hero">
          <img class="logo-mark" src={`${import.meta.env.BASE_URL}favicon_yellow.png`} alt="Логотип театра «Эмоцика»" />
        </a>
        <a href={import.meta.env.BASE_URL} class="logo-badge" data-scroll-to="hero">
          <span class="logo-text">Театр «Эмоцика»</span>
        </a>
      </div>

      {!isLanding && (
        <!-- Mobile Toggle -->
        <button class="mobile-toggle" aria-label="Меню" data-mobile-toggle>
            <span></span>
            <span></span>
            <span></span>
        </button>
      )}

      {!isLanding && (
        <nav class="main-nav" aria-label="Основная навигация" data-mobile-menu>
          <a href="/theatre" class="nav-link">Театр</a>
          <a href="/studio" class="nav-link">Студия</a>
          <a href="/cinema" class="nav-link">Киношкола</a>
          <a href="/love-tank" class="nav-link">Любовь у сливного бачка</a>
          <a href="/about" class="nav-link">О нас</a>
          <a href="/about#contacts" class="nav-link nav-link-pill">
            Записаться
          </a>
          <!-- Mobile Only CTA -->
          <a href="https://clck.ru/3QWtC2" class="nav-link nav-link-cta mobile-only" target="_blank" rel="noopener">
              Купить билеты
          </a>
        </nav>
      )}
      
      <a href="https://clck.ru/3QWtC2" class={`nav-link nav-link-cta header-cta ${!isLanding ? 'desktop-only' : ''}`} target="_blank" rel="noopener">
        Купить билеты
      </a>

    </div>
</header>

<script>
    const header = document.querySelector('.site-header');
    const toggle = document.querySelector('[data-mobile-toggle]');
    const menu = document.querySelector('[data-mobile-menu]');
    
    // Mobile Menu Logic
    if (toggle && menu) {
        toggle.addEventListener('click', () => {
            const isOpen = toggle.classList.toggle('is-active');
            menu.classList.toggle('is-active');
            document.body.style.overflow = isOpen ? 'hidden' : '';
        });

        // Close on link click
        menu.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                toggle.classList.remove('is-active');
                menu.classList.remove('is-active');
                document.body.style.overflow = '';
            });
        });
    }

    // Smart Header Logic (Hide/Show on Scroll)
    let lastScroll = 0;
    const scrollThreshold = 100; // px before logic kicks in

    if (header) {
        window.addEventListener('scroll', () => {
            const currentScroll = window.scrollY;
            
            // Add 'is-scrolled' class for styling when not at top
            if (currentScroll > 10) {
                header.classList.add('is-scrolled');
            } else {
                header.classList.remove('is-scrolled');
            }

            // Don't hide if menu is open or near top
            if (currentScroll < scrollThreshold || (menu && menu.classList.contains('is-active'))) {
                header.classList.remove('is-hidden');
                lastScroll = currentScroll;
                return;
            }

            // Don't hide header on scroll anymore (User Request)
            // if (currentScroll > lastScroll && currentScroll > scrollThreshold) {
            //    header.classList.add('is-hidden');
            //    document.body.classList.add('header-hidden');
            // } else {
            //    header.classList.remove('is-hidden');
            //    document.body.classList.remove('header-hidden');
            // }
            
            lastScroll = currentScroll;
        }, { passive: true });
    }
</script>
