---
import playsData from '../../data/plays.json';
---

<div class="playbill-grid">
    {playsData.map(play => (
        <article class="playbill-card">
            <div class="playbill-card__image-wrapper">
                 <img src={play.image.startsWith('http') ? play.image : `${import.meta.env.BASE_URL}${play.image.replace(/^\//, '')}`} alt={play.title} class="playbill-card__image" loading="lazy" />
                 <span class="playbill-card__age-badge">{play.age}</span>
            </div>
            
            <div class="playbill-card__content">
                <div class="playbill-card__meta-row">
                    <span class="playbill-card__date">{play.date}</span>
                </div>
                
                <h3 class="playbill-card__title">{play.title}</h3>
                
                <div class="playbill-card__footer">
                    <span class="playbill-card__price">{play.price}</span>
                    <!-- 
                        Yandex Afisha Button 
                        Uses standard class 'ya-ticket-button' or custom trigger if script configured so.
                        We'll use a custom data attribute for our JS adapter if needed, 
                        or just standard onclick for now which the script might intercept.
                    -->
                    <button 
                        class="btn-theatre-gold" 
                        data-yandex-ticket-event={play.yandexEventId}
                        onclick={`console.log('Open Widget for ${play.yandexEventId}')`}
                    >
                        Купить билет
                    </button>
                </div>
            </div>
        </article>
    ))}
</div>

<script>
    // Simple adapter to handle clicks if Yandex script isn't auto-binding
    document.addEventListener('click', (e) => {
        const btn = e.target.closest('[data-yandex-ticket-event]');
        if (btn) {
            // If real Yandex Widget API is present:
            // window.YandexTickets.open(btn.dataset.yandexTicketEvent)
            
            // For now, mockup alert
            const eventId = btn.dataset.yandexTicketEvent;
            
            if (window.YandexTickets) {
                 // Real API call would go here
                 console.log('Yandex API detected, opening', eventId);
            } else {
                 alert(`Здесь откроется виджет Яндекс.Афиши для события: ${eventId}\n(ID события нужно заменить на реальный)`);
            }
        }
    });
</script>
