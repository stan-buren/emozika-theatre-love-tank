---
import abonementsData from '../../data/abonements.json';

const tickets = (abonementsData || []).filter(item => !item.draft);
---

<section id="abonements" class="section section-tickets">
    <div class="container">
        <header class="section-header text-center mb-16">
            <h2 class="section-title">Билетная Касса</h2>
            <p class="section-subtitle">Выберите свой абонемент в мир театра.</p>
        </header>

        <div class="tickets-grid">
            {tickets.map(ticket => (
                <div class="ticket-card-wrapper">
                    <div class="ticket-card">
                        <div class="ticket-stub">
                            <span class="vertical-text">ADMIT ONE</span>
                            <div class="ticket-holes"></div>
                        </div>
                        <div class="ticket-body">
                            <div class="ticket-header">
                                {ticket.badge && <span class="ticket-badge">{ticket.badge}</span>}
                                <h3 class="ticket-title">{ticket.name}</h3>
                                <p class="ticket-age">{ticket.age}</p>
                            </div>
                            
                            <ul class="ticket-features">
                                {ticket.bullets && ticket.bullets.map(bullet => (
                                    <li><span>✓</span> {bullet}</li>
                                ))}
                            </ul>

                            <div class="ticket-footer">
                                <div class="price-block">
                                    <span class="price-label">Стоимость</span>
                                    <span class="price-value">{ticket.price}</span>
                                </div>
                                <button class="btn-ticket" data-open-modal="main-booking-modal">
                                    Купить Билет
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            ))}
        </div>

        <div class="tickets-note mt-12 text-center text-muted">
            <p>* В стоимость включены костюмы, фотосессии и работа гримеров.</p>
        </div>
    </div>
</section>

<style lang="scss">
    .section-tickets {
        background-color: #f4f1ea; /* Vintage Paper color */
        padding: 6rem 0;
        background-image: 
            radial-gradient(#e0ded8 1px, transparent 0),
            radial-gradient(#e0ded8 1px, transparent 0);
        background-position: 0 0, 20px 20px;
        background-size: 40px 40px;
    }

    .tickets-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 3rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .ticket-card-wrapper {
        filter: drop-shadow(0 10px 15px rgba(0,0,0,0.1));
        transition: transform 0.3s ease;

        &:hover {
            transform: translateY(-5px) rotate(1deg);
        }
    }

    .ticket-card {
        display: flex;
        background: white;
        border-radius: 8px;
        overflow: hidden;
        position: relative;
        /* Ticket texture */
        background-image: url('https://www.transparenttextures.com/patterns/cream-paper.png');
    }

    /* Left Stub */
    .ticket-stub {
        width: 60px;
        background: var(--text-accent); /* Generic accent or map specific */
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        border-right: 2px dashed rgba(255,255,255,0.4);
    }
    
    .ticket-card-wrapper:nth-child(2n) .ticket-stub {
        background: #40E0D0; /* Turquoise alternate */
    }

    .vertical-text {
        writing-mode: vertical-lr;
        transform: rotate(180deg);
        font-family: monospace;
        letter-spacing: 0.2em;
        font-weight: 700;
        opacity: 0.8;
        font-size: 0.9rem;
    }

    /* Notches */
    .ticket-card {
        mask-image: radial-gradient(circle at left center, transparent 10px, black 10px),
                    radial-gradient(circle at right center, transparent 10px, black 10px);
        mask-composite: intersect; /* CAREFUL: standard props might need prefixes or fallback */
        /* Simple fallback approach with pseudo-elements usually safer for cross-browser without extensive testing */
    }
    
    /* Using pseudo elements for notches instead of mask for better compatibility here */
    .ticket-card::before, .ticket-card::after {
        content: '';
        position: absolute;
        width: 20px;
        height: 20px;
        background: #f4f1ea; /* Match section bg */
        border-radius: 50%;
        top: 50%;
        transform: translateY(-50%);
        z-index: 2;
    }
    .ticket-card::before { left: -10px; }
    .ticket-card::after { right: -10px; }

    /* Body */
    .ticket-body {
        flex: 1;
        padding: 2rem 2rem 2rem 1.5rem;
        display: flex;
        flex-direction: column;
    }

    .ticket-header {
        margin-bottom: 1.5rem;
        border-bottom: 2px solid #eee;
        padding-bottom: 1rem;
    }

    .ticket-badge {
        display: inline-block;
        background: #000;
        color: #fff;
        padding: 4px 8px;
        font-size: 0.7rem;
        text-transform: uppercase;
        border-radius: 4px;
        margin-bottom: 0.5rem;
    }

    .ticket-title {
        font-family: var(--font-heading);
        font-size: 1.75rem;
        font-weight: 800;
        line-height: 1.1;
        margin-bottom: 0.25rem;
        color: #2D2D2D;
    }

    .ticket-age {
        color: #888;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: 0.9rem;
    }

    .ticket-features {
        list-style: none;
        padding: 0;
        margin: 0 0 2rem;
        flex: 1;

        li {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 0.75rem;
            font-size: 0.95rem;
            line-height: 1.4;
            color: #555;

            span {
                color: var(--text-accent);
                font-weight: bold;
            }
        }
    }

    .ticket-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: auto;
    }

    .price-value {
        display: block;
        font-size: 1.5rem;
        font-weight: 800;
        color: #2D2D2D;
    }
    
    .price-label {
        font-size: 0.75rem;
        color: #999;
        text-transform: uppercase;
    }

    .btn-ticket {
        background: #2D2D2D;
        color: white;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 4px; /* Less rounded for vintage feel */
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;

        &:hover {
            background: #000;
        }
    }
</style>
