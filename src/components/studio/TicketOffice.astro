---
import abonementsData from '../../data/abonements.json';

// Separate Trial from Subscriptions
const trialTicket = abonementsData.find(item => item.id === 'trial');
const subscriptionTickets = abonementsData.filter(item => item.id !== 'trial' && !item.draft);

// Helper for prices
const getPrice = (id) => {
    if (id === 'one-month') return '4 800';
    if (id === 'four-months') return '16 900';
    if (id === 'year') return '42 000';
    return '';
}
---

<!-- Import Fonts Globally for this component scope -->
<style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap');
    @import url('https://fonts.googleapis.com/css2?family=Mrs+Saint+Delafield&display=swap');
</style>

<section id="abonements" class="section section-playbill">
    <div class="container">
        
        <!-- Header -->
        <header class="playbill-header text-center fade-in">
            <span class="playbill-season">Сезон 2024 / 2025</span>
            <h2 class="playbill-title">Афиша Возможностей</h2>
            <div class="divider-gold"></div>
        </header>

        <!-- 1. The Invitation (Trial) -->
        <div class="invitation-wrapper reveal-text">
            <div class="invitation-card">
                <div class="invitation-content">
                    <span class="script-text">Приглашение</span>
                    <h3 class="invitation-header">{trialTicket.name}</h3>
                    <p class="invitation-desc">{trialTicket.description}</p>
                    <button class="btn-rsvp" data-open-modal="main-booking-modal">
                        Записаться бесплатно
                    </button>
                </div>
                <div class="invitation-stamp">
                   <div class="stamp-circle">
                       <span>First<br>Step</span>
                   </div>
                </div>
            </div>
        </div>

        <!-- 2. The Repertoire (Subscriptions) -->
        <div class="repertoire-grid reveal-text delay-1">
            {subscriptionTickets.map((ticket, index) => {
                const isHighlight = ticket.badge === "Выгодно" || ticket.id === 'four-months';
                return (
                    <div class={`playbill-column ${isHighlight ? 'is-highlight' : ''}`}>
                         {isHighlight && <div class="badge-best">Выбор Студии</div>}
                         
                         <h3 class="plan-name">{ticket.name.replace('Учебный модуль', 'Модуль').replace(' на ', ' ')}</h3>
                         <div class="plan-price">
                            <span class="currency">₽</span>
                            <span class="value">{getPrice(ticket.id)}</span>
                         </div>
                         <p class="plan-period">{ticket.id === 'one-month' ? '/ месяц' : (ticket.id === 'four-months' ? '/ за 4 месяца' : '/ год')}</p>
                         
                         <div class="plan-divider"></div>
                         
                         <ul class="plan-features">
                            {ticket.bullets && ticket.bullets.map(bullet => (
                                <li>{bullet}</li>
                            ))}
                         </ul>
                         
                         <div class="plan-action">
                             <button class="btn-playbill" data-open-modal="main-booking-modal">
                                 Оформить
                             </button>
                         </div>
                    </div>
                )
            })}
        </div>

        <div class="playbill-footer text-center mt-16 reveal-text delay-2">
            <p class="footer-note">
                <span class="asterisk">*</span> В стоимость включены все материалы, костюмы для выступлений и фотосессии.
            </p>
        </div>

    </div>
</section>

<style lang="scss">
    .section-playbill {
        background-color: #FDFCF8; /* Warm White */
        padding: 8rem 0;
        color: #1a0b2e;
        position: relative;
    }

    /* === Header === */
    .playbill-header {
        margin-bottom: 5rem;
        position: relative;
    }

    .playbill-season {
        font-family: 'Courier Prime', monospace;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.2em;
        color: #888;
        display: block;
        margin-bottom: 1rem;
    }

    .playbill-title {
        font-family: 'Playfair Display', serif; /* Elegant Serif */
        font-size: 3.5rem;
        font-weight: 400;
        margin-bottom: 1.5rem;
        color: #1a0b2e;
    }

    .divider-gold {
        width: 80px;
        height: 1px;
        background: #C5A059;
        margin: 0 auto;
    }

    /* === Invitation (Trial) === */
    .invitation-wrapper {
        max-width: 900px;
        margin: 0 auto 5rem;
    }

    .invitation-card {
        background: #fff;
        border: 1px solid rgba(197, 160, 89, 0.3); /* Subtle Gold Border */
        padding: 3rem;
        text-align: center;
        position: relative;
        box-shadow: 0 10px 40px rgba(0,0,0,0.03);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;

        /* Paper Texture */
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E");
    }

    .invitation-content {
        position: relative;
        z-index: 2;
    }

    .script-text {
        font-family: 'Mrs Saint Delafield', cursive;
        font-size: 2.5rem;
        color: #C5A059;
        display: block;
        margin-bottom: 0.5rem;
        transform: rotate(-5deg);
    }

    .invitation-header {
        font-family: 'Playfair Display', serif;
        font-size: 2.5rem;
        margin-bottom: 1rem;
        font-weight: 700;
        line-height: 1.2;
    }

    .invitation-desc {
        font-family: 'Inter', sans-serif;
        color: #666;
        max-width: 500px;
        margin: 0 auto 2rem;
        line-height: 1.6;
    }

    .btn-rsvp {
        background: #1a0b2e;
        color: #fff;
        padding: 1rem 2.5rem;
        border: none;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        border-radius: 2px;
        
        &:hover {
            background: #C5A059;
            color: #1a0b2e;
            transform: translateY(-2px);
        }
    }

    .invitation-stamp {
        position: absolute;
        top: 2rem;
        right: 2rem;
        opacity: 0.1;
        transform: rotate(15deg);
        pointer-events: none;
        
        .stamp-circle {
            width: 100px;
            height: 100px;
            border: 2px solid #000;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Courier Prime', monospace;
            text-align: center;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.9rem;
            line-height: 1.2;
        }
    }


    /* === Subscriptions Grid === */
    .repertoire-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 0; /* Connected columns */
        max-width: 1100px;
        margin: 0 auto;
        border-top: 1px solid rgba(0,0,0,0.1);
        border-bottom: 1px solid rgba(0,0,0,0.1);
    }

    .playbill-column {
        padding: 3rem 2rem;
        border-right: 1px solid rgba(0,0,0,0.1);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        position: relative;
        transition: all 0.3s ease;
        background: transparent;

        &:first-child { border-left: 1px solid rgba(0,0,0,0.1); } /* Close the box */
        
        &:hover {
            background: #fff;
            box-shadow: 0 10px 40px rgba(0,0,0,0.08);
            transform: scale(1.02);
            z-index: 5;
            border-color: transparent;
        }
        
        &.is-highlight {
            background: #fff;
            border-color: transparent;
            box-shadow: 0 5px 25px rgba(0,0,0,0.05);
            z-index: 2;
        }
    }

    .badge-best {
        position: absolute;
        top: 1rem;
        font-family: 'Courier Prime', monospace;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #C5A059;
        border: 1px solid #C5A059;
        padding: 4px 10px;
        border-radius: 50px;
    }

    .plan-name {
        font-family: 'Playfair Display', serif;
        font-size: 1.5rem;
        margin-bottom: 1.5rem;
        min-height: 3rem; /* Align */
        display: flex;
        align-items: center;
    }

    .plan-price {
        display: flex;
        align-items: flex-start;
        justify-content: center;
        color: #1a0b2e;
        line-height: 1;
        margin-bottom: 0.5rem;
    }

    .plan-price .currency {
        font-size: 1.25rem;
        margin-top: 5px;
        margin-right: 4px;
        font-family: 'Playfair Display', serif;
    }

    .plan-price .value {
        font-size: 3rem;
        font-weight: 700;
        font-family: 'Montserrat', sans-serif;
    }

    .plan-period {
        font-family: 'Courier Prime', monospace;
        font-size: 0.85rem;
        color: #999;
        margin-bottom: 2rem;
        display: block;
    }

    .plan-divider {
        width: 30px;
        height: 1px;
        background: #ddd;
        margin-bottom: 2rem;
    }

    .plan-features {
        list-style: none;
        padding: 0;
        margin: 0 0 3rem 0;
        flex: 1; /* Push button down */
        
        li {
            font-family: 'Inter', sans-serif;
            font-size: 0.95rem;
            color: #555;
            margin-bottom: 1rem;
            line-height: 1.5;
        }
    }

    .btn-playbill {
        background: transparent;
        color: #1a0b2e;
        border: 1px solid #1a0b2e;
        padding: 0.8rem 2rem;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.1em;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s;
        
        &:hover {
            background: #1a0b2e;
            color: #fff;
        }
    }
    
    .plan-action {
        width: 100%;
    }

    /* === Footer === */
    .playbill-footer {
        max-width: 600px;
        margin: 4rem auto 0;
    }
    
    .footer-note {
        font-family: 'Courier Prime', monospace;
        font-size: 0.85rem;
        color: #999;
    }

    /* Animation Utils */
    .fade-in { opacity: 0; animation: fadeIn 1s forwards; }
    .reveal-text { opacity: 0; transform: translateY(20px); animation: fadeInUp 0.8s forwards; }
    .delay-1 { animation-delay: 0.2s; }
    .delay-2 { animation-delay: 0.4s; }

    @keyframes fadeIn { to { opacity: 1; } }
    @keyframes fadeInUp { to { opacity: 1; transform: translateY(0); } }

    @media (max-width: 768px) {
        .playbill-title { font-size: 2.5rem; }
        .repertoire-grid { grid-template-columns: 1fr; border: none; gap: 2rem; }
        .playbill-column { border: 1px solid rgba(0,0,0,0.1); &:first-child { border: 1px solid rgba(0,0,0,0.1); } }
        .invitation-wrapper { margin-bottom: 3rem; }
    }
</style>
