---
<section class="final-cta">
    <div class="cta-bg-layer"></div>
    
    <div class="container relative z-10">
        <div class="cta-content text-center">
            <span class="cta-eyebrow fade-in">Твой выход</span>
            <h2 class="cta-title">
                <span class="block reveal-text">Сцена Ждет</span>
                <span class="block reveal-text delay-1 highlight">Главного Героя</span>
            </h2>
            <p class="cta-desc reveal-text delay-2">
                Не откладывайте талант на потом. Запишитесь на бесплатное пробное занятие,
                чтобы почувствовать магию театра изнутри.
            </p>
            
            <div class="cta-actions reveal-text delay-3">
                <a href="https://wa.me/79313157787" target="_blank" rel="noopener" class="btn-gold-glitch">
                    <span class="btn-text">Забронировать место</span>
                    <span class="btn-glitch"></span>
                    <span class="btn-icon">🎭</span>
                </a>
                <p class="cta-note">
                    <span class="dot">●</span> Осталось 3 места в группе на этой неделе
                </p>
            </div>
        </div>
    </div>
    
    <!-- Decorative Curtains -->
    <div class="curtain-decoration left"></div>
    <div class="curtain-decoration right"></div>
    
    <!-- Spotlight Effect -->
    <div class="spotlight-beam"></div>
</section>

<style lang="scss">
    .final-cta {
        position: relative;
        padding: 8rem 0;
        background: #0a0510;
        overflow: hidden;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 600px;
    }

    .cta-bg-layer {
        position: absolute;
        inset: 0;
        background-image: 
            radial-gradient(circle at 50% 0%, rgba(120, 50, 200, 0.4) 0%, transparent 60%),
            url("https://www.transparenttextures.com/patterns/stardust.png");
        opacity: 0.6;
        z-index: 1;
    }

    .cta-content {
        position: relative;
        z-index: 10;
        max-width: 800px;
        margin: 0 auto;
    }
    
    .cta-eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.5em;
        font-size: 0.85rem;
        color: rgba(255,255,255,0.6);
        margin-bottom: 2rem;
        display: block;
    }

    .cta-title {
        font-family: var(--font-heading);
        font-size: clamp(3rem, 7vw, 6rem);
        font-weight: 800;
        line-height: 0.95;
        margin-bottom: 2rem;
        
        .highlight {
            background: linear-gradient(135deg, #FFD700 0%, #FDB931 50%, #FFD700 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 50px rgba(255, 215, 0, 0.3);
            display: inline-block;
        }
    }

    .cta-desc {
        font-size: 1.25rem;
        line-height: 1.6;
        color: rgba(255,255,255,0.8);
        margin-bottom: 3rem;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }

    /* Glitch Button */
    .btn-gold-glitch {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        padding: 1.2rem 3rem;
        background: #D4AF37;
        color: #1a0b2e;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        text-decoration: none;
        border-radius: 4px; /* Sharp corners for premium feel */
        overflow: hidden;
        transition: transform 0.2s;
        
        &:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 30px rgba(212, 175, 55, 0.6);
            
            .btn-glitch {
                animation: glitch-anim 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) both infinite;
            }
        }
    }
    
    .btn-glitch {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(45deg, transparent 5%, rgba(255,255,255,0.5) 5%, transparent 5%);
        background-size: 200% 200%;
        opacity: 0;
        mix-blend-mode: overlay;
    }

    @keyframes glitch-anim {
        0% { transform: translate(0); opacity: 0; }
        20% { transform: translate(-5px, 5px); opacity: 1; }
        40% { transform: translate(-5px, -5px); opacity: 0; }
        60% { transform: translate(5px, 5px); opacity: 1; }
        80% { transform: translate(5px, -5px); opacity: 0; }
        100% { transform: translate(0); opacity: 1; }
    }

    .cta-note {
        margin-top: 1.5rem;
        font-size: 0.9rem;
        color: rgba(255,255,255,0.5);
        
        .dot { color: #4CAF50; animation: pulse 2s infinite; }
    }

    @keyframes pulse {
        0% { opacity: 1; } 50% { opacity: 0.5; } 100% { opacity: 1; }
    }

    /* Decorations */
    .curtain-decoration {
        position: absolute;
        top: 0; bottom: 0; width: 300px;
        background: url('https://www.transparenttextures.com/patterns/velvet.png'), linear-gradient(90deg, #1a0b2e 0%, transparent 100%);
        z-index: 2;
        pointer-events: none;
        
        &.left { left: 0; transform: scaleX(1); }
        &.right { right: 0; transform: scaleX(-1); }
    }
    
    .spotlight-beam {
        position: absolute;
        top: -50%; left: 50%;
        width: 1000px; height: 1000px;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
        transform: translateX(-50%) rotate(45deg); /* Angle beam */
        filter: blur(80px);
        pointer-events: none;
    }

    /* Animations */
    .reveal-text {
        opacity: 0;
        transform: translateY(20px);
        animation: fadeUp 0.8s ease forwards;
    }
    .delay-1 { animation-delay: 0.2s; }
    .delay-2 { animation-delay: 0.4s; }
    .delay-3 { animation-delay: 0.6s; }
    
    @keyframes fadeUp {
        to { opacity: 1; transform: translateY(0); }
    }
    
    @media (max-width: 768px) {
        .cta-title { font-size: 3.5rem; }
        .curtain-decoration { width: 100px; }
    }
</style>
