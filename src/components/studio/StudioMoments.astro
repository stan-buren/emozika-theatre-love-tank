---
import newsData from '../../data/vk_news.json';

// Get just the last 8 items for the "Moments" feel
const moments = newsData.slice(0, 8);

// Random rotation generator helper
function getRandomRotation() {
    return (Math.random() * 8 - 4).toFixed(1); // -4 to +4 deg
}
---

<section class="section-moments">
    <div class="container">
        <div class="moments-header text-center mb-16">
            <span class="eyebrow">Закулисье</span>
            <h2 class="section-title">Живые Моменты</h2>
            <p class="section-subtitle">Случайные кадры нашей театральной жизни</p>
        </div>

        <div class="polaroid-wall">
            {moments.map((item, index) => (
                <a 
                    href={item.link} 
                    target="_blank" 
                    rel="noopener" 
                    class="polaroid-card" 
                    style={`--rotation: ${getRandomRotation()}deg; --delay: ${index * 0.1}s`}
                >
                    <div class="polaroid-frame">
                         <div class="image-area">
                             <img src={item.image} alt="Moment" class="moment-image" loading="lazy" />
                             <div class="shine-overlay"></div>
                         </div>
                         <div class="caption-area">
                            <span class="handwritten-date">{item.date}</span>
                            <p class="handwritten-caption">{item.excerpt}</p>
                         </div>
                    </div>
                    <div class="tape-piece"></div>
                </a>
            ))}
        </div>
        
        <div class="text-center mt-12">
            <a href="https://vk.com/emozika" target="_blank" class="btn-vk-more">
                <span class="vk-symbol">VK</span> Смотреть все истории
            </a>
        </div>
    </div>
</section>

<style lang="scss">
    /* Import Handwriting Font */
    @import url('https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&display=swap');

    .section-moments {
        padding: 6rem 0;
        background-color: #f8f5f2; /* Soft warm gray */
        /* Subtle generated noise texture instead of cork */
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E");
        overflow: hidden;
    }

    .eyebrow {
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.15em;
        color: #8E44AD;
        font-weight: 700;
        display: block;
        margin-bottom: 0.5rem;
    }

    .section-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
        color: #2c1e0b;
    }
    
    .section-subtitle {
        font-family: 'Inter', sans-serif;
        color: #666;
    }

    .polaroid-wall {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 3rem;
        max-width: 1300px;
        margin: 0 auto;
        padding: 2rem;
    }

    .polaroid-card {
        text-decoration: none;
        color: inherit;
        position: relative;
        transform: rotate(var(--rotation));
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        z-index: 1;
        width: 260px;
        
        &:hover {
             transform: scale(1.1) rotate(0deg);
             z-index: 100;
             filter: drop-shadow(0 25px 50px rgba(0,0,0,0.2));
        }
    }

    .polaroid-frame {
        background: #fff;
        padding: 12px 12px 40px 12px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        transition: box-shadow 0.3s;
        /* Slight paper texture on frame */
        background-image: linear-gradient(to bottom right, #fff, #f8f8f8);
    }

    .image-area {
        width: 100%;
        aspect-ratio: 1;
        background: #eee;
        overflow: hidden;
        position: relative;
        border: 1px solid #f0f0f0;
    }

    .moment-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: sepia(0.15) contrast(1.05); /* Modern vintage */
        transition: transform 0.6s ease;
    }
    
    .polaroid-card:hover .moment-image {
        transform: scale(1.1);
        filter: sepia(0) contrast(1.1);
    }

    .shine-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.3) 0%, transparent 60%);
        pointer-events: none;
    }

    .caption-area {
        position: absolute;
        bottom: 5px;
        left: 0; right: 0;
        text-align: center;
        font-family: 'Caveat', cursive, sans-serif;
        color: #2c3e50;
        padding: 0 10px;
    }

    .handwritten-date {
        display: none; /* Hide date for cleaner look, or keep small */
    }

    .handwritten-caption {
        font-size: 1.3rem;
        line-height: 1.1;
        margin: 0;
        transform: rotate(-1deg);
        color: #1a0b2e;
        opacity: 0.9;
        
        display: -webkit-box;
        -webkit-line-clamp: 1; /* Only 1 line caption */
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Sticker Tape effect */
    .tape-piece {
        position: absolute;
        top: -12px;
        left: 50%;
        transform: translateX(-50%) rotate(2deg);
        width: 80px;
        height: 24px;
        background-color: rgba(255, 255, 255, 0.4);
        box-shadow: 0 1px 2px rgba(0,0,0,0.1);
        backdrop-filter: blur(2px);
        border: 1px solid rgba(255,255,255,0.3);
        opacity: 0.8;
    }

    .btn-vk-more {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        background: white;
        color: #0077FF; /* VK Blue for text/brand */
        padding: 0.8rem 2rem;
        border-radius: 50px;
        font-weight: 700;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.3s;
        box-shadow: 0 5px 20px rgba(0, 119, 255, 0.15);
        border: 1px solid rgba(0, 119, 255, 0.1);
        
        &:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(0, 119, 255, 0.25);
            background: #0077FF;
            color: white;
            
            .vk-symbol { background: white; color: #0077FF; }
        }
    }
    
    .vk-symbol {
        background: #0077FF;
        color: white;
        font-weight: 900;
        width: 24px; height: 24px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.7rem;
        transition: all 0.3s;
    }
</style>
