---
import awardsData from '../../data/vk_awards.json';

interface Props {
  limit?: number;
}

const { limit } = Astro.props;
const displayItems = limit ? awardsData.slice(0, limit) : awardsData;
---

<div class="awards-wall">
    <div class="wall-grid">
    {displayItems.map((award, index) => (
        <article class="diploma-frame" style={`--delay: ${index * 0.1}s`}>
            <div class="frame-wood">
                <div class="frame-matte">
                    <div class="frame-content">
                        {award.image ? (
                            <img src={award.image} alt={award.sublabel} class="diploma-img" loading="lazy" />
                        ) : (
                            <div class="diploma-placeholder">
                                <span class="cup">🏆</span>
                            </div>
                        )}
                        <div class="glass-reflection"></div>
                    </div>
                </div>
            </div>
            
            <div class="diploma-plaque">
                <span class="diploma-year">{new Date(award.date).getFullYear()}</span>
                <h4 class="diploma-title">{award.label}</h4>
                <p class="diploma-desc">{award.sublabel}</p>
            </div>
        </article>
    ))}
    </div>
</div>

<style lang="scss">
    .awards-wall {
        padding: 4rem 0;
        background: 
            linear-gradient(rgba(255,255,255,0.9), rgba(255,255,255,0.9)),
            url("https://www.transparenttextures.com/patterns/white-wall-3.png");
    }

    .wall-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 3rem;
        justify-content: center;
        max-width: 1200px;
        margin: 0 auto;
    }

    .diploma-frame {
        max-width: 350px; /* Constrain max size */
        margin: 0 auto;   /* Center in grid cell */
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        opacity: 0;
        animation: hangOnWall 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        animation-delay: var(--delay);
        transform-origin: top center;

        &:hover {
            z-index: 10;
            
            .frame-wood {
                transform: scale(1.05) rotate(0deg) !important;
                box-shadow: 0 20px 50px rgba(0,0,0,0.2);
            }
        }

        /* Random slight tilt for realism */
        &:nth-child(odd) .frame-wood { transform: rotate(-1deg); }
        &:nth-child(even) .frame-wood { transform: rotate(1deg); }
        &:nth-child(3n) .frame-wood { transform: rotate(0.5deg); }
    }

    .frame-wood {
        background: #2c1e12; /* Dark wood wood */
        padding: 12px;
        border-radius: 4px;
        box-shadow: 
            2px 4px 10px rgba(0,0,0,0.2),
            inset 0 0 0 2px rgba(255,255,255,0.1);
        transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
        position: relative;
    }

    .frame-matte {
        background: #fff;
        padding: 20px;
        box-shadow: inset 0 0 10px rgba(0,0,0,0.1);
    }

    .frame-content {
        position: relative;
        width: 100%;
        aspect-ratio: 1/1.414; /* A4 aspect ratio */
        overflow: hidden;
        border: 1px solid #eee;
    }

    .diploma-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .diploma-placeholder {
        width: 100%;
        height: 100%;
        background: #f4f1ea;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: #d4af37;
        background-image: radial-gradient(#d4af37 1px, transparent 1px);
        background-size: 20px 20px;
        opacity: 0.5;
    }

    .glass-reflection {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: linear-gradient(135deg, rgba(255,255,255,0.4) 0%, transparent 40%, rgba(255,255,255,0.1) 100%);
        pointer-events: none;
    }

    /* Little Golden Plaque below frame */
    .diploma-plaque {
        margin-top: 1.5rem;
        background: linear-gradient(to bottom, #cfc09f 0%, #ffecb3 50%, #b3a076 100%);
        padding: 8px 16px;
        border-radius: 4px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        text-align: center;
        min-width: 200px;
        border: 1px solid #998866;
        position: relative;
        
        /* Screws */
        &::before, &::after {
            content: '';
            position: absolute;
            top: 50%;
            width: 4px;
            height: 4px;
            background: #665544;
            border-radius: 50%;
            transform: translateY(-50%);
            box-shadow: 0 1px 0 rgba(255,255,255,0.5);
        }
        &::before { left: 6px; }
        &::after { right: 6px; }
    }

    .diploma-year {
        display: block;
        font-size: 0.7rem;
        font-weight: 800;
        color: #5d4037;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .diploma-title {
        font-family: var(--font-heading);
        font-size: 0.95rem;
        font-weight: 700;
        color: #3e2723;
        margin: 2px 0;
        line-height: 1.2;
    }

    .diploma-desc {
        font-size: 0.75rem;
        color: #5d4037;
        opacity: 0.9;
    }

    @keyframes hangOnWall {
        from { 
            opacity: 0; 
            transform: translateY(-50px) rotate(5deg); 
        }
        to { 
            opacity: 1; 
            transform: translateY(0) rotate(0); 
        }
    }
</style>
