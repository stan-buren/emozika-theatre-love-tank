---
<section class="stage-hero" id="stage-hero">
    <div class="curtain curtain--left">
        <div class="curtain-fabric"></div>
        <div class="curtain-tassel"></div>
    </div>
    <div class="curtain curtain--right">
        <div class="curtain-fabric"></div>
        <div class="curtain-tassel"></div>
    </div>
    
    <div class="stage-content">
        <div class="spotlight-beam" id="cursor-spotlight"></div>
        <div class="container text-center relative z-10">
            <span class="eyebrow fade-in">Для детей 4–16 лет</span>
            <h1 class="stage-title">
                <span class="line reveal-text">Твой Выход</span>
                <span class="line reveal-text delay-1">На Сцену</span>
            </h1>
            <p class="stage-subtitle reveal-text delay-2">
                Студия, где застенчивость превращается в харизму,<br>а детская игра — в настоящее искусство.
            </p>
            <div class="stage-actions reveal-text delay-3">
                <button class="btn-stage-primary shimmer-btn" data-open-modal="main-booking-modal">
                    Записаться на пробу
                </button>
                <a href="#studio-journey" class="btn-stage-secondary">
                    Путь актера
                </a>
            </div>
        </div>
        
        <!-- Bottom Fog/Floor -->
        <div class="stage-floor"></div>
    </div>
</section>

<script>
    function initHero() {
        // Trigger curtain animation
        document.body.classList.remove('curtains-open');
        setTimeout(() => {
            document.body.classList.add('curtains-open');
        }, 300); // Slight delay for dramatic effect

        // Spotlight Following Cursor
        const hero = document.getElementById('stage-hero');
        const beam = document.getElementById('cursor-spotlight');
        
        if (hero && beam) {
            hero.addEventListener('mousemove', (e) => {
                const rect = hero.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                // Allow the beam to move slightly with the cursor for a 3D feel
                // But keep it centered-ish on the text mostly
                const moveX = (x / rect.width) * 20 - 10; // -10% to 10%
                const moveY = (y / rect.height) * 20 - 10;

                beam.style.transform = `translate(calc(-50% + ${moveX}px), calc(-20% + ${moveY}px))`;
            });
        }
    }

    initHero();
    document.addEventListener('astro:after-swap', initHero);
</script>

<style lang="scss">
    .stage-hero {
        position: relative;
        height: 100vh;
        min-height: 700px;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #05010a; /* Vantablack-ish */
        overflow: hidden;
        color: white;
        perspective: 1000px;
        /* Ensure it sits below the fixed header but above generic content initially */
        z-index: 1; 
    }

    /* --- CURTAINS --- */
    .curtain {
        position: absolute;
        top: 0;
        bottom: 0;
        width: 55%; /* Overlap slightly */
        z-index: 20; /* Lower than header but high */
        transition: transform 3s cubic-bezier(0.25, 1, 0.5, 1); /* Slower, heavier feel */
        pointer-events: none; /* Crucial: clicks pass through even if open */
        
        &--left {
            left: 0;
            transform-origin: top left;
            box-shadow: 10px 0 50px rgba(0,0,0,0.9);
        }
        
        &--right {
            right: 0;
            transform-origin: top right;
            box-shadow: -10px 0 50px rgba(0,0,0,0.9);
            
            .curtain-fabric {
                background-position: right center;
            }
        }
    }

    .curtain-fabric {
        width: 100%;
        height: 100%;
        /* Deep Velvet Texture: Dark Purple with a repeating fold pattern + Noise */
        background-color: #2a083b;
        background-image: 
            repeating-linear-gradient(90deg, 
                #3a0d58 0%, 
                #1a0526 4%, 
                #2a083b 8%, 
                #3a0d58 12%
            );
        /* Add some "noise" via filter if we had an image, but css gradient is cleaner */
        box-shadow: inset 0 0 100px rgba(0,0,0,0.8); 
    }

    /* Open State */
    :global(body.curtains-open) .curtain--left {
        transform: translate3d(-90%, 0, 0) rotateY(10deg) scaleX(0.9); 
    }
    :global(body.curtains-open) .curtain--right {
        transform: translate3d(90%, 0, 0) rotateY(-10deg) scaleX(0.9);
    }

    /* Lighting */
    .spotlight-beam {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 1200px;
        height: 1200px;
        background: radial-gradient(circle, rgba(142, 68, 173, 0.15) 0%, transparent 60%);
        filter: blur(60px);
        opacity: 0;
        animation: lightOn 2.5s ease forwards 1.2s; /* Delayed start */
        pointer-events: none;
        transition: transform 0.1s ease-out; /* Smooth follow */
    }

    .stage-content {
        position: relative;
        z-index: 10;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: radial-gradient(circle at center, #1b0a26 0%, #000 90%);
    }

    /* Typography */
    .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.3em;
        font-size: 0.85rem;
        color: #f1c40f; /* Soft Gold */
        margin-bottom: 2rem;
        opacity: 0.8;
        display: inline-block;
    }

    .stage-title {
        font-family: var(--font-heading);
        font-size: clamp(3.5rem, 9vw, 8rem);
        font-weight: 800;
        line-height: 0.95;
        margin-bottom: 2.5rem;
        text-shadow: 0 20px 60px rgba(0,0,0,0.7);
        
        .line { display: block; }
    }

    .stage-subtitle {
        font-size: 1.3rem;
        color: rgba(255,255,255,0.85); /* Brighter */
        font-weight: 300;
        margin-bottom: 3.5rem;
        line-height: 1.6;
        text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    }

    /* Action Buttons */
    .stage-actions {
        display: flex;
        gap: 1.5rem;
        justify-content: center;
        align-items: center;
    }

    .btn-stage-primary {
        position: relative;
        background: linear-gradient(135deg, #f1c40f 0%, #d4af37 100%); /* Gold Gradient */
        color: #2c1e0b;
        padding: 1.2rem 3rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-radius: 99px;
        overflow: hidden;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 10px 40px rgba(241, 196, 15, 0.2);

        &:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 50px rgba(241, 196, 15, 0.4);
        }
    }

    .shimmer-btn::after {
        content: '';
        position: absolute;
        top: 0; left: -100%;
        width: 50%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.7), transparent);
        transform: skewX(-20deg);
        animation: shimmer 3s infinite;
    }

    .btn-stage-secondary {
        color: rgba(255,255,255,0.7);
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border-bottom: 1px solid rgba(255,255,255,0.3);
        padding-bottom: 2px;
        transition: color 0.3s, border-color 0.3s;
        text-decoration: none;

        &:hover {
            color: #fff;
            border-color: #fff;
        }
    }

    @keyframes shimmer {
        0% { left: -100%; }
        20% { left: 200%; }
        100% { left: 200%; }
    }

    @keyframes lightOn {
        from { opacity: 0; }
        to { opacity: 1; }
    }

    .reveal-text {
        opacity: 0;
        transform: translateY(30px);
        animation: fadeUp 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
        
        &.delay-1 { animation-delay: 1.8s; }
        &.delay-2 { animation-delay: 2.1s; }
        &.delay-3 { animation-delay: 2.4s; }
    }

    @keyframes fadeUp {
        to { opacity: 1; transform: translateY(0); }
    }
    
    /* Mobile Adjustments */
    @media (max-width: 768px) {
        .curtain { width: 60%; }
    }
</style>
