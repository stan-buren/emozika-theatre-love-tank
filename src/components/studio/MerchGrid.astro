---
const fantasyGoods = [
  {
    id: 1,
    title: "Худи «Режиссёр»",
    price: "3 500 ₽",
    image: "/assets/img/shop/merch_hoodie_emozika_1765370174082.png",
    tag: "Хит",
    soldOut: true
  },
  {
    id: 2,
    title: "Футболка «Я в моменте»",
    price: "1 800 ₽",
    image: "/assets/img/shop/merch_tshirt_actor_1765370186897.png",
    tag: "New"
  },
  {
    id: 3,
    title: "Шоппер «Театр — это жизнь»",
    price: "990 ₽",
    image: "/assets/img/shop/merch_shopper_theatre_1765370204344.png",
    tag: ""
  }
];
---

<section id="shop" class="section section-shop">
  <div class="container">
    <header class="section-header text-center">
      <h2 class="section-title section-title--serif">Мерч студии</h2>
      <p class="section-subtitle">Одежда и аксессуары для тех, кто живет театром.</p>
    </header>

    <div class="merch-grid">
      {fantasyGoods.map(item => (
        <article class={`merch-card ${item.soldOut ? 'is-sold-out' : ''}`}>
          <div class="merch-card__image-wrapper">
             {item.soldOut && <div class="sold-out-overlay"><span>Sold Out</span></div>}
             {item.tag && !item.soldOut && <span class="merch-card__tag">{item.tag}</span>}
             <img src={item.image.startsWith('http') ? item.image : `${import.meta.env.BASE_URL}${item.image.replace(/^\//, '')}`} alt={item.title} class="merch-card__image" loading="lazy" />
          </div>
          <div class="merch-card__content">
            <h3 class="merch-card__title">{item.title}</h3>
            
            {item.soldOut ? (
                <p class="merch-card__price price-muted">Нет в наличии</p>
            ) : (
                <p class="merch-card__price">{item.price}</p>
            )}
            
            {item.soldOut ? (
                <button class="btn-merch btn-disabled" disabled>Раскупили</button>
            ) : (
                <a href={`https://wa.me/79313157787?text=Здравствуйте! Хочу заказать ${item.title}`} target="_blank" class="btn-merch">
                    Заказать
                </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  /* Global Font Import for component scope consistency */
  @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap');

  .section-shop {
      padding: 6rem 0;
      background: #fff;
  }

  .text-center { text-align: center; margin-bottom: 4rem; }
  
  .section-title--serif { 
      font-family: 'Playfair Display', serif;
      font-weight: 700; 
      font-size: 3rem; 
      margin-bottom: 1rem;
      color: #1a0b2e;
  }

  .section-subtitle {
     color: #666;
     font-size: 1.1rem;
     font-family: 'Inter', sans-serif;
  }

  .merch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .merch-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    /* Clean, Apple-like with gold touch */
    border: 1px solid rgba(0,0,0,0.04);
    transition: all 0.4s ease;
    display: flex;
    flex-direction: column;

    &:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        border-color: rgba(197, 160, 89, 0.3); /* Muted gold border */
    }
    
    &.is-sold-out {
        opacity: 0.7;
        pointer-events: none;
        filter: grayscale(0.8);
    }
  }

  .merch-card__image-wrapper {
    position: relative;
    padding-top: 100%; /* 1:1 Aspect Ratio */
    background: transparent;
    overflow: hidden;
    
    img {
        position: absolute;
        top: 0; left: 0;
        width: 100%;
        height: 100%;
        object-fit: contain;
        padding: 0; 
        transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
  }
  
  .sold-out-overlay {
      position: absolute;
      inset: 0;
      background: rgba(255,255,255,0.6);
      z-index: 5;
      display: flex;
      align-items: center;
      justify-content: center;
      
      span {
          background: #000;
          color: #fff;
          padding: 8px 16px;
          text-transform: uppercase;
          font-weight: 800;
          font-family: 'Courier Prime', monospace;
          transform: rotate(-10deg);
          border: 2px solid #fff;
      }
  }

  .merch-card:hover .merch-card__image { transform: scale(1.08); }

  .merch-card__tag {
    position: absolute;
    top: 16px;
    left: 16px;
    background: #8E44AD; /* Brand Purple */
    color: #fff;
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    z-index: 2;
    box-shadow: 0 4px 10px rgba(142, 68, 173, 0.2);
  }

  .merch-card__content {
    padding: 2rem 1.5rem;
    text-align: center;
    flex-direction: column;
    display: flex;
    flex: 1;
  }

  .merch-card__title {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #1a1a1a;
    line-height: 1.3;
  }

  .merch-card__price {
    display: block;
    font-size: 1.25rem;
    font-weight: 800;
    color: #C5A059; /* Brand Gold */
    margin-bottom: 2rem;
    font-family: 'Montserrat', sans-serif;
  }
  
  .price-muted {
      color: #999;
      text-decoration: line-through;
      font-size: 1rem;
  }

  .btn-merch {
    margin-top: auto;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    padding: 1rem 1.5rem;
    background: transparent;
    color: #1a1a1a;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.3s ease;
    font-weight: 600;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;

    &:hover {
        background: #1a0b2e;
        color: white;
        border-color: #1a0b2e;
        box-shadow: 0 5px 15px rgba(26, 11, 46, 0.2);
    }
  }
  
  .btn-disabled {
      border-color: #eee;
      color: #999;
      background: #f5f5f5;
      cursor: not-allowed;
      &:hover {
          background: #f5f5f5;
          color: #999;
          border-color: #eee;
          box-shadow: none;
      }
  }
</style>
