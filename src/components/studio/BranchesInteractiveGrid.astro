---
interface Props {
  branches: any[];
}

const { branches } = Astro.props;

function getGradient(color: string) {
    const map: Record<string, string> = {
        purple: "linear-gradient(135deg, #7a2fb4 0%, #4a1f6b 100%)",
        blue: "linear-gradient(135deg, #40E0D0 0%, #20B2AA 100%)",
        orange: "linear-gradient(135deg, #FFD700 0%, #FFA500 100%)",
        green: "linear-gradient(135deg, #90EE90 0%, #32CD32 100%)",
        cyan: "linear-gradient(135deg, #E0FFFF 0%, #00FFFF 100%)",
        red: "linear-gradient(135deg, #FF6347 0%, #FF4500 100%)"
    };
    return map[color] || map.purple;
}
---

<div class="branch-cards-grid">
    {branches.map(branch => {
        const isAdults = branch.isAdults; 
        const link = branch.mapLink || "#yandex-map";
        const gradient = getGradient(branch.photoUrl);
        
        return (
            <article 
                class="branch-interactive-card" 
                data-metro={(branch.metro || "").toLowerCase()} 
                data-adults={isAdults ? "" : undefined}
                tabindex="0"
            >
                <div class="card-visual" style={`background: ${gradient}`}>
                    <span class="visual-icon">🏛️</span>
                    {isAdults && <span class="badge-18">18+</span>}
                </div>
                
                <div class="card-content">
                    <div class="card-header">
                        <h3 class="card-title">{branch.place}</h3>
                        <div class="card-metro-row">
                             <span class="metro-dot"></span>
                             <span class="card-metro">{branch.metro || "Метро"}</span>
                        </div>
                    </div>
                    
                    <p class="card-address">{branch.address}</p>
                    
                    <div class="card-footer">
                        <a href={link} class="card-link" target="_blank">
                            Показать на карте →
                        </a>
                    </div>
                </div>
            </article>
        );
    })}
</div>

<style lang="scss">
    .branch-cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 2rem;
        padding-top: 2rem;
    }

    .branch-interactive-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid rgba(0,0,0,0.02);
        display: flex;
        flex-direction: column;

        &:hover, &:focus {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(122, 47, 180, 0.1);
        }
    }

    .card-visual {
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
    }

    .visual-icon {
        font-size: 2.5rem;
        opacity: 0.15;
    }

    .badge-18 {
        position: absolute;
        top: 10px;
        right: 10px;
        background: black;
        color: white;
        font-size: 0.7rem;
        font-weight: 700;
        padding: 4px 8px;
        border-radius: 4px;
    }

    .card-content {
        padding: 1.5rem;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .card-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        line-height: 1.3;
        color: #2D2D2D;
    }

    .card-metro-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 1rem;
    }

    .metro-dot {
        width: 8px;
        height: 8px;
        background: #D70100; /* Generic metro red, or varied */
        border-radius: 50%;
    }

    .card-metro {
        font-size: 0.9rem;
        color: #555;
        font-weight: 500;
    }

    .card-address {
        font-size: 0.9rem;
        color: #888;
        margin-bottom: 1.5rem;
        line-height: 1.4;
    }

    .card-footer {
        margin-top: auto;
    }

    .card-link {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--text-accent);
        text-decoration: none;
        
        &:hover {
            text-decoration: underline;
        }
    }
</style>
