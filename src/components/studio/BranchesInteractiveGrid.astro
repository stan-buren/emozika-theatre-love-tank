---
interface Props {
  branches: any[];
}

const { branches } = Astro.props;

function getGradient(color: string) {
    const map: Record<string, string> = {
        purple: "linear-gradient(135deg, #8E44AD 0%, #3a0d58 100%)",
        blue: "linear-gradient(135deg, #3498DB 0%, #2980B9 100%)",
        orange: "linear-gradient(135deg, #F39C12 0%, #D35400 100%)",
        green: "linear-gradient(135deg, #2ECC71 0%, #27AE60 100%)",
        cyan: "linear-gradient(135deg, #1ABC9C 0%, #16A085 100%)",
        red: "linear-gradient(135deg, #E74C3C 0%, #C0392B 100%)"
    };
    return map[color] || map.purple;
}
---

<div class="branch-cards-grid">
    {branches.map(branch => {
        const isAdults = branch.isAdults; 
        const link = branch.mapLink || "#yandex-map";
        const gradient = getGradient(branch.photoUrl);
        
        return (
            <article 
                class="branch-interactive-card" 
                data-metro={(branch.metro || "").toLowerCase()} 
                data-adults={isAdults ? "" : undefined}
                data-cinema={branch.isCinema ? "" : undefined}
                data-branch-id={branch.id}
                data-coords={JSON.stringify(branch.coords || [0,0])}
                tabindex="0"
            >
                <div class="card-visual" style={`background: ${gradient}`}>
                    <div class="visual-content">
                        <span class="visual-icon">📍</span>
                        <span class="view-interior-label">👀 Смотреть зал</span>
                    </div>
                    {isAdults && <span class="badge-18">18+</span>}
                    <!-- Placeholder for future Video Loop -->
                    <div class="video-placeholder-overlay"></div>
                </div>
                
                <div class="card-content">
                    <div class="card-header">
                        <h3 class="card-title">{branch.place}</h3>
                        <div class="card-metro-row">
                             <span class="metro-dot"></span>
                             <span class="card-metro">{branch.metro || "Санкт-Петербург"}</span>
                        </div>
                    </div>
                    
                    <p class="card-address">{branch.address}</p>
                    
                    <div class="card-footer">
                        <a href={link} class="card-link" target="_blank">
                            Маршрут →
                        </a>
                    </div>
                </div>
            </article>
        );
    })}
</div>

<script>
    function initBranchInteractions() {
        const cards = document.querySelectorAll('.branch-interactive-card');
        
        cards.forEach(card => {
            // Hover: Highlight Pin on Map
            card.addEventListener('mouseenter', () => {
                const coords = JSON.parse((card as HTMLElement).dataset.coords || "[0,0]");
                document.dispatchEvent(new CustomEvent('highlight-map-pin', {
                    detail: { coords, id: (card as HTMLElement).dataset.branchId }
                }));
            });

            card.addEventListener('mouseleave', () => {
                document.dispatchEvent(new CustomEvent('reset-map-pin'));
            });
        });
    }

    initBranchInteractions();
    document.addEventListener('astro:after-swap', initBranchInteractions);
</script>

<style lang="scss">
    .branch-cards-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2rem;
        padding-top: 2rem;
    }

    .branch-interactive-card {
        background: white;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.3s ease;
        border: 1px solid rgba(0,0,0,0.03);
        display: flex;
        flex-direction: column;
        height: 100%;
        position: relative;

        &:hover, &:focus-within {
            transform: translateY(-8px);
            box-shadow: 0 20px 50px rgba(58, 13, 88, 0.15);
            z-index: 2;

            .view-interior-label {
                opacity: 1;
                transform: translateY(0);
            }
            
            .visual-icon {
                opacity: 0;
            }
        }
    }

    .card-visual {
        height: 160px;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .visual-content {
        position: relative;
        z-index: 2;
        text-align: center;
        width: 100%;
    }

    .visual-icon {
        font-size: 4rem;
        opacity: 0.3;
        transition: opacity 0.3s;
        display: block;
    }

    .view-interior-label {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, 20px);
        background: rgba(0,0,0,0.7);
        color: white;
        padding: 8px 16px;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 600;
        opacity: 0;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        white-space: nowrap;
    }

    .badge-18 {
        position: absolute;
        top: 12px;
        right: 12px;
        background: rgba(0,0,0,0.8);
        -webkit-backdrop-filter: blur(4px);
        backdrop-filter: blur(4px);
        color: #F1C40F;
        font-size: 0.75rem;
        font-weight: 800;
        padding: 4px 8px;
        border-radius: 6px;
        z-index: 5;
        border: 1px solid rgba(241, 196, 15, 0.5);
    }

    .card-content {
        padding: 1.5rem;
        flex: 1;
        display: flex;
        flex-direction: column;
        background: white;
    }

    .card-header {
        margin-bottom: 1rem;
    }

    .card-title {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        line-height: 1.2;
        color: #2c1e0b;
    }

    .card-metro-row {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .metro-dot {
        width: 8px;
        height: 8px;
        background: #E74C3C;
        border-radius: 50%;
    }

    .card-metro {
        font-size: 0.9rem;
        color: #666;
        font-weight: 600;
    }

    .card-address {
        font-size: 0.9rem;
        color: #888;
        margin-bottom: 1.5rem;
        line-height: 1.5;
        border-top: 1px dashed #eee;
        padding-top: 1rem;
    }

    .card-footer {
        margin-top: auto;
    }

    .card-link {
        font-size: 0.85rem;
        font-weight: 700;
        color: #8E44AD;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: gap 0.2s;
        
        &:hover {
            gap: 10px;
            color: #6c3483;
        }
    }

    /* Highlight Animation triggered from Parent */
    :global(.highlight-pulse) {
        animation: pulseHighlight 0.8s ease;
        border: 2px solid #F1C40F !important;
        box-shadow: 0 0 0 4px rgba(241, 196, 15, 0.2), 0 20px 60px rgba(0,0,0,0.15) !important;
        transform: scale(1.03);
        z-index: 10;
        
        .card-visual {
            filter: brightness(1.1);
        }
    }

    @keyframes pulseHighlight {
        0% { transform: scale(1); }
        50% { transform: scale(1.05); }
        100% { transform: scale(1.03); }
    }
</style>
