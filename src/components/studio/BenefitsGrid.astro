---
interface Props {
    title?: string;
}

const { title = "Почему мамы выбирают «Эмоцику»?" } = Astro.props;

const benefits = [
    { icon: "👗", title: "Костюмерная включена", text: "Вам не нужно шить костюмы ночами или искать реквизит. Мы всё предоставляем сами." },
    { icon: "📸", title: "Контент в подарок", text: "Профессиональные фото и видео со спектаклей уже включены в абонемент." },
    { icon: "🎭", title: "Своя сцена", text: "Мы не арендуем ДК. Дети выступают на профессиональной сцене в Гранд Каньоне." }
];
---

<section class="section benefits-section">
    <div class="container relative z-10">
        <header class="section-header text-center mb-16">
            <span class="eyebrow">Для спокойствия родителей</span>
            <h2 class="section-title">{title}</h2>
        </header>
        
        <div class="benefits-grid">
            {benefits.map((item, index) => (
                <div class="benefit-card glass-card" style={`--delay: ${index * 0.1}s`}>
                    <div class="benefit-icon-wrapper">
                        <span class="benefit-emoji">{item.icon}</span>
                        <div class="benefit-check">✓</div>
                    </div>
                    <div class="benefit-content">
                        <h3 class="benefit-title">{item.title}</h3>
                        <p class="benefit-text">{item.text}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<style lang="scss">
    .benefits-section {
        background: linear-gradient(180deg, #f9f9f9 0%, #fff 100%);
        padding: 6rem 0;
        position: relative;
        overflow: hidden;
    }

    .eyebrow {
        display: block;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.15em;
        color: var(--text-muted);
        margin-bottom: 1rem;
        font-weight: 600;
    }

    .benefits-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        max-width: 1100px;
        margin: 0 auto;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        border-radius: 24px;
        padding: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        transition: transform 0.4s ease, box-shadow 0.4s ease;
        display: flex;
        align-items: flex-start;
        gap: 1.5rem;
        animation: fadeUp 0.6s ease forwards;
        animation-delay: var(--delay);
        opacity: 0;
        transform: translateY(20px);

        &:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            border-color: #fff;
            background: #fff;
        }
    }

    .benefit-icon-wrapper {
        position: relative;
        flex-shrink: 0;
        width: 60px;
        height: 60px;
        background: #fff;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 20px rgba(0,0,0,0.06);
    }

    .benefit-emoji {
        font-size: 2rem;
    }

    .benefit-check {
        position: absolute;
        bottom: -5px;
        right: -5px;
        width: 24px;
        height: 24px;
        background: #4CAF50;
        color: white;
        border-radius: 50%;
        font-size: 14px;
        font-weight: bold;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid #fff;
    }

    .benefit-title {
        font-size: 1.25rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        color: var(--text-main);
    }

    .benefit-text {
        font-size: 0.95rem;
        line-height: 1.6;
        color: var(--text-muted);
    }

    @keyframes fadeUp {
        to { opacity: 1; transform: translateY(0); }
    }
</style>
