---
import peopleData from '../../data/people.json';

// Filter only the main team who are teachers
const teamGroup = peopleData.groups.find(g => g.id === 'team')?.people || [];
const teachers = teamGroup.filter(person => person.tags && person.tags.includes('педагог'));
---

<section id="super-teachers" class="section section-teachers">
  <div class="container">
    <header class="section-header text-center mb-12">
      <h2 class="section-title">Наши Супер-Педагоги</h2>
      <p class="section-subtitle max-w-2xl mx-auto">
        В каждом из них скрыта суперсила, которая помогает детям раскрываться. Наведите, чтобы узнать!
      </p>
    </header>

    <div class="teachers-grid">
      {teachers.map((person) => (
        <article class="teacher-card" tabindex="0">
          <div class="teacher-card__inner">
            <!-- Front -->
            <div class="teacher-card__front">
                <div class="media-wrapper">
                    {person.photoUrl 
                        ? <img src={`/${person.photoUrl}`} alt={person.name} loading="lazy" />
                        : <div class="placeholder">{person.name[0]}</div>
                    }
                </div>
                <div class="info">
                    <h3 class="name">{person.name}</h3>
                    <p class="role">{person.shortRole}</p>
                </div>
            </div>

            <!-- Back (Overlay) -->
            <div class="teacher-card__back">
                <div class="superpower-badge">Суперсила</div>
                <h3 class="superpower-title">{person.superpower || 'Магия Театра ✨'}</h3>
                <p class="bio">{person.bio}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  .teachers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
    padding-bottom: 2rem;
  }

  .teacher-card {
    position: relative;
    height: 420px;
    border-radius: var(--radius-card);
    overflow: hidden;
    cursor: pointer;
    background: var(--bg-card);
    box-shadow: var(--shadow-card);
    transition: transform 0.3s ease, box-shadow 0.3s ease;

    &:hover, &:focus {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(122, 47, 180, 0.15);

        .teacher-card__back {
            opacity: 1;
            transform: translateY(0);
        }
    }
  }

  .teacher-card__inner {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .teacher-card__front {
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .media-wrapper {
    flex: 1;
    overflow: hidden;
    position: relative;
    
    img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }
    
    .placeholder {
        width: 100%;
        height: 100%;
        background: #f0f0f0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: #ccc;
    }
  }

  .info {
    padding: 1.25rem;
    background: white;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .name {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .role {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  /* Reveal State */
  .teacher-card__back {
    position: absolute;
    inset: 0;
    background: rgba(122, 47, 180, 0.95); /* Studio Purple Accent */
    color: white;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(4px);
    z-index: 2;
  }

  .superpower-badge {
    background: #FFD700;
    color: #000;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.75rem;
    padding: 4px 12px;
    border-radius: 99px;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }

  .superpower-title {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .bio {
    font-size: 0.95rem;
    line-height: 1.5;
    opacity: 0.9;
    max-height: 200px;
    overflow-y: auto;
    
    /* Scrollbar for bio */
    &::-webkit-scrollbar { width: 4px; }
    &::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.3); border-radius: 4px; }
  }
</style>
