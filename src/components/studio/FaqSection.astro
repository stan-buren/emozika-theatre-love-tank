---
import FaqList from '../FaqList.astro';
import faqData from '../../data/faq.json';
---

<section id="faq" class="section section--faq reveal-on-scroll">
  <div class="container container--narrow">
    <header class="section-header text-center mb-16">
      <span class="eyebrow">База знаний</span>
      <h2 class="section-title">Вопросы родителей</h2>
      <p class="section-subtitle">
        Мы знаем, что вас волнует. Честные ответы на самые частые вопросы.
      </p>
    </header>

    <div class="faq-chat-layout">
        <div class="faq-group">
            <h3 class="group-label">Для начинающих</h3>
            <div class="chat-bubbles">
                {[faqData[2], faqData[3], faqData[7]].map(item => (
                    <details class="chat-item">
                        <summary class="chat-question">
                            <span class="avatar-q">?</span>
                            <span class="text">{item.question}</span>
                            <span class="toggle-icon"></span>
                        </summary>
                        <div class="chat-answer">
                            <div class="avatar-a">E</div>
                            <div class="text-bubble">{item.answer}</div>
                        </div>
                    </details>
                ))}
            </div>
        </div>

        <div class="faq-group">
            <h3 class="group-label">Организация и Оплата</h3>
            <div class="chat-bubbles">
                {[faqData[0], faqData[1], faqData[5]].map(item => (
                    <details class="chat-item">
                        <summary class="chat-question">
                            <span class="avatar-q">?</span>
                            <span class="text">{item.question}</span>
                            <span class="toggle-icon"></span>
                        </summary>
                        <div class="chat-answer">
                            <div class="avatar-a">E</div>
                            <div class="text-bubble">{item.answer}</div>
                        </div>
                    </details>
                ))}
            </div>
        </div>
        
         <div class="faq-group">
            <h3 class="group-label">Результат</h3>
            <div class="chat-bubbles">
                {[faqData[4], faqData[6]].map(item => (
                    <details class="chat-item">
                        <summary class="chat-question">
                            <span class="avatar-q">?</span>
                            <span class="text">{item.question}</span>
                            <span class="toggle-icon"></span>
                        </summary>
                        <div class="chat-answer">
                            <div class="avatar-a">E</div>
                            <div class="text-bubble">{item.answer}</div>
                        </div>
                    </details>
                ))}
            </div>
        </div>
    </div>
  </div>
</section>

<style lang="scss">
    .section--faq {
        background: #fdfdfd;
        padding: 6rem 0;
    }

    .container--narrow {
        max-width: 900px;
    }
    
    .eyebrow {
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.15em;
        color: #C5A059; /* Brand Gold */
        display: block;
        margin-bottom: 1rem;
        font-weight: 700;
        font-family: 'Courier Prime', monospace;
    }

    .section-title {
        color: #1a0b2e;
        font-family: 'Montserrat', sans-serif;
        font-size: 2.5rem;
        font-weight: 800;
    }
    
    .section-subtitle {
        font-family: 'Inter', sans-serif;
        color: #666;
    }

    .faq-chat-layout {
        display: grid;
        gap: 4rem;
    }

    .faq-group {
        position: relative;
    }
    
    .group-label {
        font-family: 'Montserrat', sans-serif;
        font-size: 1.5rem;
        color: #1a0b2e;
        margin-bottom: 2rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        font-weight: 700;
        
        &::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(0,0,0,0.1);
        }
    }

    .chat-bubbles {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    /* Message Bubble Style */
    .chat-item {
        transition: all 0.3s ease;
        
        &[open] {
            .chat-question { 
                background: #1a0b2e; 
                color: white;
                transform: translateX(10px);
                box-shadow: 0 10px 20px rgba(26, 11, 46, 0.15);
            }
            .avatar-q { background: rgba(255,255,255,0.2); color: white; }
            .toggle-icon { transform: rotate(45deg); opacity: 1; }
            .toggle-icon::before, .toggle-icon::after { background: white; }
        }
    }

    .chat-question {
        list-style: none;
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding: 1.25rem 1.5rem;
        border-radius: 16px 16px 16px 4px; /* Message bubble shape */
        background: white;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 4px 15px rgba(0,0,0,0.03);
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        position: relative;
        z-index: 1;
        
        &::-webkit-details-marker { display: none; }
        
        &:hover { 
            transform: translateX(5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.06);
            border-color: rgba(197, 160, 89, 0.3);
        }
    }
    
    .avatar-q {
        width: 36px; height: 36px;
        background: #f5f5f5;
        color: #1a0b2e;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700;
        flex-shrink: 0;
        font-family: 'Montserrat', sans-serif;
        transition: all 0.3s;
    }
    
    .chat-question .text {
        font-weight: 600;
        font-size: 1.1rem;
        flex: 1;
        line-height: 1.4;
    }
    
    .toggle-icon {
        width: 24px; height: 24px;
        position: relative;
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        opacity: 0.3;
        
        &::before, &::after {
            content: ''; position: absolute;
            top: 50%; left: 50%;
            background: #1a0b2e;
            transform: translate(-50%, -50%);
            transition: background 0.3s;
        }
        &::before { width: 12px; height: 2px; }
        &::after { width: 2px; height: 12px; }
    }

    .chat-answer {
        padding: 1.5rem 0 0 3rem;
        animation: slideIn 0.4s ease;
        position: relative;
        display: flex;
        gap: 1rem;
    }
    
    .avatar-a {
        width: 36px; height: 36px;
        background: linear-gradient(135deg, #C5A059 0%, #b8860b 100%);
        color: white;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-weight: 800;
        font-size: 0.9rem;
        flex-shrink: 0;
        box-shadow: 0 4px 10px rgba(197, 160, 89, 0.3);
    }
    
    .text-bubble {
        background: #fff;
        padding: 1.5rem 2rem;
        border-radius: 4px 16px 16px 16px;
        color: #444;
        line-height: 1.7;
        font-size: 1rem;
        border: 1px solid rgba(197, 160, 89, 0.15);
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        position: relative;
        
        &::before { /* Triangle */
            content: '';
            position: absolute;
            top: 0; left: -8px;
            width: 0; height: 0;
            border-top: 10px solid white;
            border-left: 10px solid transparent;
        }
    }

    @keyframes slideIn {
        from { opacity: 0; transform: translateY(-10px) translateX(-10px); }
        to { opacity: 1; transform: translateY(0) translateX(0); }
    }
</style>
