---
import peopleData from '../data/people.json';

const { class: className } = Astro.props;
---

<section id="people" class={`section section-people section-card reveal-on-scroll ${className || ''}`}>
  <div class="section-inner">
    <div class="container">
      <header class="section-header">
        <h2 class="section-title section-title--handdrawn">Люди театра</h2>
        <p class="section-subtitle">За спектаклями и занятиями в «Эмоцике» стоят режиссёры, педагоги, актёры и юные
          артисты студии. Здесь только часть нашей команды и звёзд студии.</p>
        <div class="section-chips">
          <span class="chip">Режиссёры</span>
          <span class="chip">Педагоги</span>
          <span class="chip">Юные артисты</span>
        </div>
      </header>
      <div class="people-shell">
        
        <!-- People Filter -->
        <div class="people-filter" data-people-filter>
            {(peopleData.groups || []).map((group, index) => (
            <button 
                class={`people-filter__btn ${index === 0 ? 'is-active' : ''}`} 
                type="button" 
                data-group={group.id}
            >
                {group.title}
            </button>
            ))}
        </div>

        <!-- People Grid -->
        <div class="people-grid" data-people-grid>
            {(peopleData.groups || []).map((group, groupIndex) => 
            (group.people || []).map((person, itemIndex) => (
                <article 
                class={`person-card ${groupIndex !== 0 ? 'hidden-group' : ''}`}
                data-group={group.id}
                data-role={person.role}
                style={groupIndex !== 0 || itemIndex >= 8 ? 'display: none;' : ''}
                >
                <div class="person-photo">
                    {person.photoUrl 
                    ? <img src={`${import.meta.env.BASE_URL}${person.photoUrl.replace(/^\//, '')}`} alt={person.name} loading="lazy" />
                    : <div class="person-placeholder">{person.name[0]}</div>
                    }
                </div>
                <div class="person-content">
                    <h3 class="person-name">{person.name}</h3>
                    <p class="person-role">{person.role}</p>
                    {person.bio && <p class="person-bio">{person.bio}</p>}
                </div>
                </article>
            ))
            )}
        </div>

        <div class="people-actions">
            <button class="btn btn--outline" type="button" data-people-load-more>
            Показать ещё
            </button>
        </div>

      </div>
    </div>
  </div>
</section>
