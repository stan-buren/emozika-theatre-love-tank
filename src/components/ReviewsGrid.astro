---
interface Props {
  reviews: any[];
}

const { reviews } = Astro.props;

// Split reviews to create a masonry effct manually or use CSS columns
const activeReviews = reviews.filter(r => r.isActive);
---

<div class="reviews-masonry" data-reviews-masonry aria-label="Стена любви родителей">
    {activeReviews.map((review, index) => (
      <article 
        class={`review-card ${review.videoEmbedUrl ? 'review-card--video' : 'review-card--text'} ${index % 5 === 0 ? 'review-card--featured' : ''}`}
        data-review-id={review.id}
        data-video-url={review.videoEmbedUrl}
        data-quote={review.quote}
        data-title={review.title}
        data-author={review.authorLabel}
        data-meta={[review.yearsInStudioLabel, review.branch].filter(Boolean).join(' • ')}
        tabindex="0"
      >
        {review.videoEmbedUrl ? (
            <div class="card-media">
                <div class="play-icon">▶</div>
                <img src={review.thumbUrl || `https://source.unsplash.com/random/400x600?theatre,kid,${index}`} alt={review.title} loading="lazy" />
                <div class="video-overlay"></div>
            </div>
        ) : (
            <div class="card-quote-body">
                <div class="quote-icon">“</div>
                <p class="review-quote">{review.quote || "Спасибо за чудесные занятия!"}</p>
            </div>
        )}

        <div class="card-footer">
            <h3 class="author-name">{review.authorLabel}</h3>
            <p class="review-meta">
                 {[review.yearsInStudioLabel, review.branch].filter(Boolean).join(' • ')}
            </p>
        </div>
      </article>
    ))}
</div>

<style lang="scss">
    /* Import Handwriting Font if not global, but assuming it might be added globally. If not, fallback to cursive. */
    @import url('https://fonts.googleapis.com/css2?family=Caveat:wght@400;700&display=swap');

    .reviews-masonry {
        column-count: 3;
        column-gap: 2rem;
        padding: 2rem 0;
        
        @media (max-width: 900px) { column-count: 2; }
        @media (max-width: 600px) { column-count: 1; }
    }

    .review-card {
        break-inside: avoid-column;
        background: #fff;
        border-radius: 2px; /* More like paper note */
        margin-bottom: 2rem;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        overflow: hidden;
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: 1px solid rgba(0,0,0,0.03);
        cursor: pointer;
        position: relative;
        
        /* Wall of Love - slight random rotations handled by CSS nth-child */
        &:nth-child(3n) { transform: rotate(1deg); }
        &:nth-child(3n+1) { transform: rotate(-1deg); }
        &:nth-child(3n+2) { transform: rotate(0.5deg); }
        
        &:hover {
            transform: translateY(-8px) scale(1.02) rotate(0deg) !important;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            z-index: 2;
        }

        &--featured {
            background: #1a0b2e; /* Deep Purple */
            color: white;
            
            .review-quote { 
                color: rgba(255,255,255,0.9); 
                font-family: 'Montserrat', sans-serif; /* Featured is serious/bold */
                font-style: italic;
            }
            .author-name { color: white; }
            .review-meta { color: rgba(255,255,255,0.6); }
            .quote-icon { color: #C5A059; opacity: 1; }
        }
    }

    /* Video Card Styles */
    .card-media {
        position: relative;
        aspect-ratio: 9/16; /* Portrait Video aesthetic */
        background: #000;
        
        img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.9;
            transition: opacity 0.3s;
        }
        
        .video-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 40%);
        }
        
        .play-icon {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 60px; height: 60px;
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(10px);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 24px;
            border: 1px solid rgba(255,255,255,0.4);
            transition: transform 0.3s, background 0.3s;
            z-index: 10;
        }
    }
    
    .review-card:hover .play-icon {
        transform: translate(-50%, -50%) scale(1.2);
        background: white;
        color: black;
    }

    /* Text Quote Styles */
    .card-quote-body {
        padding: 2.5rem 2rem 1rem 2rem;
        position: relative;
        background-color: #fffdf9; /* Warm paper */
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.03'/%3E%3C/svg%3E");
    }
    
    .quote-icon {
        position: absolute;
        top: 1rem;
        left: 1rem;
        font-family: serif;
        font-size: 4rem;
        line-height: 1;
        color: rgba(142, 68, 173, 0.1); /* Soft Purple tint */
        pointer-events: none;
    }
    
    .review-quote {
        font-family: 'Caveat', cursive; /* Handwritten feel */
        font-size: 1.4rem;
        line-height: 1.4;
        color: #2c1e0b;
        position: relative;
        z-index: 1;
    }

    /* Footer Meta */
    .card-footer {
        padding: 1.5rem;
        border-top: 1px dashed rgba(0,0,0,0.05); /* Dashed line for notes */
        background: #fffdf9;
        
        .review-card--video & {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            border-top: none;
            background: transparent;
            color: white;
            z-index: 5;
        }
        
        .review-card--featured & {
             background: transparent;
             border-top-color: rgba(255,255,255,0.1);
        }
    }
    
    .author-name {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.95rem;
        font-weight: 700;
        margin-bottom: 0.2rem;
        color: #1a0b2e;
        
        .review-card--video & { color: white; }
    }
    
    .review-meta {
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        
        .review-card--video & { color: rgba(255,255,255,0.7); }
    }
</style>
