---
interface Props {
  reviews: any[];
}

const { reviews } = Astro.props;

// Split reviews to create a masonry effct manually or use CSS columns
const activeReviews = reviews.filter(r => r.isActive);
---

<div class="reviews-masonry" data-reviews-masonry aria-label="Стена любви родителей">
    {activeReviews.map((review, index) => (
      <article 
        class={`review-card ${review.videoEmbedUrl ? 'review-card--video' : 'review-card--text'} ${index % 5 === 0 ? 'review-card--featured' : ''}`}
        data-review-id={review.id}
        data-video-url={review.videoEmbedUrl}
        tabindex="0"
      >
        {review.videoEmbedUrl ? (
            <div class="card-media">
                <div class="play-icon">▶</div>
                <img src={review.thumbUrl || `https://source.unsplash.com/random/400x600?theatre,kid,${index}`} alt={review.title} loading="lazy" />
                <div class="video-overlay"></div>
            </div>
        ) : (
            <div class="card-quote-body">
                <div class="quote-icon">“</div>
                <p class="review-quote">{review.quote || "Спасибо за чудесные занятия!"}</p>
            </div>
        )}

        <div class="card-footer">
            <h3 class="author-name">{review.authorLabel}</h3>
            <p class="review-meta">
                 {[review.yearsInStudioLabel, review.branch].filter(Boolean).join(' • ')}
            </p>
        </div>
      </article>
    ))}
</div>

<style lang="scss">
    .reviews-masonry {
        column-count: 3;
        column-gap: 2rem;
        padding: 2rem 0;
        
        @media (max-width: 900px) { column-count: 2; }
        @media (max-width: 600px) { column-count: 1; }
    }

    .review-card {
        break-inside: avoid;
        background: #fff;
        border-radius: 20px;
        margin-bottom: 2rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        overflow: hidden;
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: 1px solid rgba(0,0,0,0.03);
        cursor: pointer;
        position: relative;
        
        &:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            z-index: 2;
        }

        &--featured {
            background: #1a0b2e;
            color: white;
            
            .review-quote { color: rgba(255,255,255,0.9); font-size: 1.2rem; }
            .author-name { color: white; }
            .review-meta { color: rgba(255,255,255,0.6); }
            .quote-icon { color: #d4af37; opacity: 1; }
        }
    }

    /* Video Card Styles */
    .card-media {
        position: relative;
        aspect-ratio: 9/16; /* Portrait Video aesthetic */
        background: #000;
        
        img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.9;
            transition: opacity 0.3s;
        }
        
        .video-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 40%);
        }
        
        .play-icon {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 60px; height: 60px;
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(10px);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 24px;
            border: 1px solid rgba(255,255,255,0.4);
            transition: transform 0.3s, background 0.3s;
            z-index: 10;
        }
    }
    
    .review-card:hover .play-icon {
        transform: translate(-50%, -50%) scale(1.2);
        background: white;
        color: black;
    }

    /* Text Quote Styles */
    .card-quote-body {
        padding: 2.5rem 2rem 1rem 2rem;
        position: relative;
    }
    
    .quote-icon {
        position: absolute;
        top: 1rem;
        left: 1rem;
        font-family: serif;
        font-size: 4rem;
        line-height: 1;
        color: rgba(122, 47, 180, 0.1);
        pointer-events: none;
    }
    
    .review-quote {
        font-size: 1.05rem;
        line-height: 1.6;
        color: #333;
        font-style: italic;
        position: relative;
        z-index: 1;
    }

    /* Footer Meta */
    .card-footer {
        padding: 1.5rem;
        border-top: 1px solid rgba(0,0,0,0.03);
        
        .review-card--video & {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            border-top: none;
            color: white;
            z-index: 5;
        }
    }
    
    .author-name {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 0.2rem;
    }
    
    .review-meta {
        font-size: 0.8rem;
        color: #888;
        
        .review-card--video & { color: rgba(255,255,255,0.7); }
    }
</style>
