---
import Layout from '../layouts/Layout.astro';
import PeopleSection from '../components/PeopleSection.astro';
import AwardsStrip from '../components/AwardsStrip.astro';
import FestivalsList from '../components/FestivalsList.astro';
import galleryData from '../data/gallery.json';
import vkGalleryData from '../data/vk_gallery.json';
import statsData from '../data/stats.json';
import awardsData from '../data/awards.json';
import { getTopAwards, getSortedFestivals } from '../utils/awards-helpers.js';

const topAwards = getTopAwards(awardsData);
const sortedFestivals = getSortedFestivals(awardsData);
---

<Layout title="О театре и команде | Театр «Эмоцика»" description="История театра «Эмоцика», наша команда педагогов и режиссеров, отзывы родителей, фотогалерея и документы." theme="light">
  <main id="main-content">
    
    <!-- Hero -->
    <section class="section section-page-header">
      <div class="container">
        <h1 class="page-title">О театре</h1>
        <p class="text-xl mt-4 max-w-2xl">
          С 2012 года мы создаем пространство, где дети становятся свободными, счастливыми и творческими.
        </p>
      </div>
    </section>

    <!-- People (Team) -->
    <section id="people" class="section section-people section-card reveal-on-scroll">
      <div class="section-inner">
        <div class="container">
          <header class="section-header">
            <h2 class="section-title section-title--handdrawn">Люди театра</h2>
            <p class="section-subtitle">За спектаклями и занятиями в «Эмоцике» стоят режиссёры, педагоги, актёры и юные артисты.</p>
          </header>
          <div class="people-shell">
            <div class="people-filters" data-people-filters role="tablist"></div>
            <div class="people-layout" data-people-root></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats (History) -->
    <section id="stats" class="section section-facts reveal-on-scroll">
      <div class="container">
        <h2 class="section-title">Цифры и факты</h2>
        <div class="facts-grid">
          {statsData.map(stat => (
            <article class="fact-card">
              <h3 class="fact-number stat-number" data-target={stat.number} data-suffix={stat.suffix}>{stat.label}</h3>
              <p class="fact-label">{stat.sublabel}</p>
              <p class="fact-text">{stat.text}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Awards -->
    <section id="awards" class="section section-awards reveal-on-scroll">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">Награды и фестивали</h2>
          <p class="section-subtitle">Спектакли и фильмы «Эмоцики» регулярно получают гран-при.</p>
        </div>
        <div class="awards-strip-shell">
          <AwardsStrip awards={topAwards} />
        </div>
        <FestivalsList festivals={sortedFestivals} />
      </div>
    </section>

    <!-- Gallery (History/Backstage) -->
    <section id="gallery" class="section section-gallery">
      <div class="container">
        <header class="section-header">
          <h2 class="section-title section__title">Галерея</h2>
          <p class="section-subtitle section__subtitle">
            Кадры с репетиций, спектаклей и закулисья.
          </p>
        </header>

        <div class="gallery">
          <div class="gallery__scroller-wrapper">
            <div class="gallery__scroller" data-gallery-scroller>
              {[...vkGalleryData, ...galleryData].map((item, index) => (
                <button type="button" class="gallery-card" data-gallery-id={item.id} data-gallery-index={index} data-category={item.category}>
                  <div class="gallery-card__image-wrapper">
                    <img src={item.src} alt={item.alt} class="gallery-card__image" loading="lazy" />
                  </div>
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Docs -->
    <section id="docs" class="section section-docs section-card">
      <div class="section-inner">
        <div class="container">
          <header class="section-header">
            <h2 class="section-title">Документы</h2>
          </header>
          <div class="docs">
            <ul class="docs-list">
              <li class="docs-item">
                <a href="/assets/docs/license.pdf" class="docs-link" target="_blank">
                  <span class="docs-title">Лицензия на образовательную деятельность</span>
                </a>
              </li>
              <li class="docs-item">
                <a href="/assets/docs/contract-sample.pdf" class="docs-link" target="_blank">
                  <span class="docs-title">Образец договора</span>
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>
