---
import Layout from '../../layouts/Layout.astro';
import PeopleSection from '../../components/PeopleSection.astro';
import BenefitsGrid from '../../components/studio/BenefitsGrid.astro';
import TicketOffice from '../../components/studio/TicketOffice.astro';
// Migrated Components
import BranchesSection from '../../components/studio/BranchesSection.astro';
import ReviewsSection from '../../components/studio/ReviewsSection.astro';
import StudioMoments from '../../components/studio/StudioMoments.astro';
import AwardsShelf from '../../components/studio/AwardsShelf.astro';
import MerchGrid from '../../components/studio/MerchGrid.astro';
import TeacherSuperheroes from '../../components/studio/TeacherSuperheroes.astro';
import StudioStageHero from '../../components/studio/StudioStageHero.astro';
import StudioJourneyMap from '../../components/studio/StudioJourneyMap.astro';
import FaqSection from '../../components/studio/FaqSection.astro';
import StudioFinalCTA from '../../components/studio/StudioFinalCTA.astro';
---

<Layout title="Театральная Студия Эмоцика | Развитие через сцену" description="Театральная студия для детей от 4 до 16 лет. Спектакли на профессиональной сцене, костюмы включены." theme="studio">
  <main class="studio-page">
    
    <!-- Hero Section (Point B) -->
    <StudioStageHero />

    <!-- 1. Pain Points Solver (Warm Grid) -->
    <BenefitsGrid title="Почему мамы выбирают «Эмоцику»?" />

    <!-- 2. Abonements (Ticket Office - Point B) -->
    <TicketOffice />

    <!-- 3. Studio Journey (Point B) -->
    <StudioJourneyMap />

    <!-- 4. Super Teachers (Point B) -->
    <TeacherSuperheroes />

    <!-- 5. Branches (Interactive Point B) -->
    <BranchesSection />

    <!-- 6. Reviews (Polished) -->
    <ReviewsSection />
    
    <!-- 7. Studio Moments (Insta-Pulse Point B) -->
    <StudioMoments />
    
    <!-- 8. Awards (Trophy Shelf Point B) -->
    <section class="section">
         <div class="container">
             <header class="section-header text-center">
                 <h2 class="section-title">Наши Победы</h2>
                 <p class="section-subtitle">Дипломы и кубки с городских и международных фестивалей.</p>
             </header>
             <AwardsShelf limit={8} />
         </div>
    </section>

    <!-- 9. Merch (Fantasy Shop) -->
    <MerchGrid />

    <!-- 7. Contacts -->
    <!-- 7. Contacts / Final CTA (Epic) -->
    <StudioFinalCTA />

    <!-- 8. FAQ (Moved from About) -->
    <FaqSection />

  </main>
</Layout>
