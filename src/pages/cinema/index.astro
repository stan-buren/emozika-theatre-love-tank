---
import Layout from '../../layouts/Layout.astro';
import CinemaHero from '../../components/cinema/CinemaHero.astro';
import TracksSplit from '../../components/cinema/TracksSplit.astro';
import ProfessionsGrid from '../../components/cinema/ProfessionsGrid.astro';
import VideoLibrary from '../../components/cinema/VideoLibrary.astro';
import ActorCardGenerator from '../../components/cinema/ActorCardGenerator.astro';
---

<Layout title="Киношкола Эмоцика | Старт карьеры в кино" description="Киношкола для подростков в Санкт-Петербурге. Актерское мастерство, режиссура, блогинг. Съемки в реальных проектах." theme="dark">
    <main class="cinema-page">
        <!-- Hero: Старт Карьеры -->
        <CinemaHero />
        
        <!-- Tracks: Актер vs Фильммейкер -->
        <TracksSplit />
        
        <!-- Professions: Кем я стану? -->
        <ProfessionsGrid />
        
        <!-- Social Proof: Наши дети на ТВ (Video Library) -->
        <VideoLibrary />

        <!-- Interactive: Generator (Point B) -->
        <ActorCardGenerator />
        
        <!-- CTA Section -->
        <section id="casting" class="section-dark" style="text-align: center;">
            <h2 class="cinema-hero__title glitch" data-text="ТВОЙ ПЕРВЫЙ ДУБЛЬ" style="font-size: 2.5rem; margin-bottom: 2rem;">
                ТВОЙ ПЕРВЫЙ ДУБЛЬ
            </h2>
            <button class="btn-cinema-gold">
                Записаться на кастинг
            </button>
        </section>
    </main>
</Layout>
