---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="«Любовь у сливного бачка» | Спектакль театра Эмоцика" 
  description="Острая комедия по пьесе Василия Сигарева в театре «Эмоцика». В ролях: Елена Молодан, Михаил Драгунов. Режиссер Евгений Баранов."
  theme="theatre"
  isLanding={true}
>
  <main class="love-tank-page">
    
    <!-- СЕКЦИЯ 1: Сплит-геро (Split Hero) -->
    <section class="lt-hero">
      <div class="lt-hero__meta-top-left">спектакль</div>
      <div class="lt-hero__meta-bottom-right">
        <span class="lt-hero__meta-label">по пьесе</span>
        <span class="lt-hero__meta-author">Василия Сигарева</span>
      </div>

      <div class="lt-hero__half lt-hero__half--poetess">
        <div class="lt-hero__img-container">
          <img src="/assets/img/lubov_u_slivnogo_bochka/poetess_alone.jpg" alt="Елена Молодан — Поэтесса" class="lt-hero__img" />
        </div>
        <div class="lt-hero__content">
          <h1 class="lt-hero__title lt-hero__title--poetess">«Любовь</h1>
        </div>
      </div>
      
      <div class="lt-hero__half lt-hero__half--plumber">
        <div class="lt-hero__img-container">
          <img src="/assets/img/lubov_u_slivnogo_bochka/plumber_alone.jpg" alt="Михаил Драгунов — Сантехник" class="lt-hero__img" />
        </div>
        <div class="lt-hero__content">
          <h1 class="lt-hero__title lt-hero__title--plumber">у сливного бачка»</h1>
        </div>
      </div>

      <!-- Разделитель: медная труба и манометр с вентилем внизу -->
      <div class="lt-hero__divider" aria-hidden="true">
        <div class="lt-hero__pipe"></div>
        
        <!-- Манометрическая станция внизу -->
        <div class="lt-hero__gauge-station">
          <!-- Тройник трубы под прибором -->
          <div class="gauge-fitting"></div>
          
          <!-- Интерактивный вентиль с оберткой для дрожания -->
          <div class="gauge-valve-wrapper">
            <div class="gauge-valve-wheel" role="button" aria-label="Сбросить давление">
              <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="50" cy="50" r="42" stroke="#b03a2e" stroke-width="8" fill="none" />
                <circle cx="50" cy="50" r="38" stroke="#78281f" stroke-width="2" fill="none" />
                <circle cx="50" cy="50" r="14" stroke="#78281f" stroke-width="4" fill="#566573" />
                <line x1="50" y1="8" x2="50" y2="36" stroke="#78281f" stroke-width="8" stroke-linecap="round" />
                <line x1="50" y1="64" x2="50" y2="92" stroke="#78281f" stroke-width="8" stroke-linecap="round" />
                <line x1="8" y1="50" x2="36" y2="50" stroke="#78281f" stroke-width="8" stroke-linecap="round" />
                <line x1="64" y1="50" x2="92" y2="50" stroke="#78281f" stroke-width="8" stroke-linecap="round" />
                <circle cx="50" cy="50" r="6" fill="#2d3748" />
              </svg>
            </div>
          </div>

          <!-- Прибор манометра -->
          <div class="gauge-dial">
            <!-- Цифры шкалы от 0 до 8 -->
            <div class="gauge-num" style="--angle: -140deg">0</div>
            <div class="gauge-num" style="--angle: -105deg">1</div>
            <div class="gauge-num" style="--angle: -70deg">2</div>
            <div class="gauge-num" style="--angle: -35deg">3</div>
            <div class="gauge-num" style="--angle: 0deg">4</div>
            <div class="gauge-num" style="--angle: 35deg">5</div>
            <div class="gauge-num" style="--angle: 70deg">6</div>
            <div class="gauge-num" style="--angle: 105deg">7</div>
            <div class="gauge-num" style="--angle: 140deg">8</div>

            <span class="gauge-unit">кгс/см²</span>
            <div class="gauge-needle"></div>
            <div class="gauge-center-cap"></div>
            <div class="gauge-glass"></div>
          </div>
          
          <!-- Облака пара при сбросе -->
          <div class="gauge-steam-container">
            <div class="steam-puff steam-puff--1"></div>
            <div class="steam-puff steam-puff--2"></div>
            <div class="steam-puff steam-puff--3"></div>
          </div>

          <!-- Острые струйки пара по бокам (для красной зоны, каждая имеет по 3 облака-частицы) -->
          <div class="gauge-jets-container">
            <div class="steam-jet steam-jet--left-1">
              <div class="jet-puff jet-puff--1"></div>
              <div class="jet-puff jet-puff--2"></div>
              <div class="jet-puff jet-puff--3"></div>
            </div>
            <div class="steam-jet steam-jet--left-2">
              <div class="jet-puff jet-puff--1"></div>
              <div class="jet-puff jet-puff--2"></div>
              <div class="jet-puff jet-puff--3"></div>
            </div>
            <div class="steam-jet steam-jet--right-1">
              <div class="jet-puff jet-puff--1"></div>
              <div class="jet-puff jet-puff--2"></div>
              <div class="jet-puff jet-puff--3"></div>
            </div>
            <div class="steam-jet steam-jet--right-2">
              <div class="jet-puff jet-puff--1"></div>
              <div class="jet-puff jet-puff--2"></div>
              <div class="jet-puff jet-puff--3"></div>
            </div>
          </div>
          
          <!-- Информационные плашки -->
          <div class="gauge-meta">
            <span class="gauge-badge gauge-badge--large">12+</span>
          </div>
        </div>
      </div>
    </section>

    <!-- СЕКЦИЯ 2: Сценическое повествование (Storytelling Narrative) -->
    <section class="lt-narrative">
      <div class="container lt-narrative__container">
        <div class="lt-narrative__content scroll-reveal">
          
          <!-- Блок 1 -->
          <div class="lt-narrative__block">
            <h3 class="lt-narrative__subtitle">Как начинается?</h3>
            <p class="lt-narrative__text">
              Случайная поломка. Чужой мужик в её доме. Она нервная, с порога — на разрыв. 
              Он невозмутимый — как бетонная стена. Она цепляет его словами. Он отвечает — не словами.
            </p>
          </div>

          <!-- Блок 2: Поэтический -->
          <div class="lt-narrative__block">
            <h3 class="lt-narrative__subtitle">Соблазнение</h3>
            <p class="lt-narrative__text lt-narrative__text--poetic">
              Соблазнение — не в поцелуях.<br/>
              Оно в том, как он молчит, когда она говорит.<br/>
              В том, как она хочет его разбудить — и вдруг просыпается сама.<br/>
              В паузах, которые говорят больше, чем любая её рифма.
            </p>
          </div>

          <!-- Блок 3 -->
          <div class="lt-narrative__block">
            <h3 class="lt-narrative__subtitle">Чем заканчивается?</h3>
            <p class="lt-narrative__text">
              Тем, что стихи заканчиваются. А он остаётся.
            </p>
            <p class="lt-narrative__text">
              Она привыкла всё контролировать. Прописывать. Додумывать. А он — просто берёт. 
              И оказывается, что за грубостью — нежность. За молчанием — глубина. А за случайным 
              вызовом сантехника — то, что она не писала в своих тетрадях.
            </p>
            <p class="lt-narrative__highlight">Настоящее.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- СЕКЦИЯ 3: О спектакле «Анатомия одиночества» (Synopsis) -->
    <section class="lt-about">
      <div class="lt-about__bg">
        <img src="/assets/img/lubov_u_slivnogo_bochka/poetess_and_plumber.jpg" alt="Сцена из спектакля" class="lt-about__bg-img" />
      </div>
      <div class="container lt-about__container">
        
        <div class="lt-about__grid">
          <div class="lt-about__quote-col">
            <blockquote class="lt-about__quote">
              «Человек живёт на земле не для того, чтобы стать богатым, но для того, чтобы стать счастливым».
            </blockquote>
            <div class="lt-about__meta-grid">
              <div class="lt-meta-item">
                <span class="lt-meta-label">Жанр</span>
                <span class="lt-meta-val">Острая комедия</span>
              </div>
              <div class="lt-meta-item">
                <span class="lt-meta-label">Продолжительность</span>
                <span class="lt-meta-val">1 час 30 минут</span>
              </div>
              <div class="lt-meta-item">
                <span class="lt-meta-label">Премьера</span>
                <span class="lt-meta-val">13 декабря 2025 г.</span>
              </div>
              <div class="lt-meta-item">
                <span class="lt-meta-label">Площадка</span>
                <span class="lt-meta-val">Камерная сцена (50 мест)</span>
              </div>
            </div>
          </div>
          
          <div class="lt-about__text-col">
            <h2 class="lt-section-title">О спектакле</h2>
            <div class="lt-about__video-wrapper">
              <video 
                src="/assets/video/lubov_u_slivnogo_rolik.mp4" 
                poster="/assets/img/lubov_u_slivnogo_bochka/poetess_poster.png"
                controls 
                preload="metadata"
                class="lt-about__video"
              >
                Ваш браузер не поддерживает встроенные видео.
              </video>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- СЕКЦИЯ 4: Создатели спектакля (Creative Team) -->
    <section class="lt-team">
      <div class="container">
        <h2 class="lt-section-title text-center">Создатели спектакля</h2>
        
        <div class="lt-team__grid">
          <!-- Режиссер -->
          <div class="lt-member-card lt-member-card--director">
            <div class="lt-member-card__photo-wrapper">
              <img src="/assets/img/people/evgeny-baranov.webp" alt="Евгений Баранов" class="lt-member-card__photo" />
            </div>
            <div class="lt-member-card__content">
              <span class="lt-member-card__role">Режиссёр-постановщик</span>
              <h3 class="lt-member-card__name">Евгений Баранов</h3>
              <p class="lt-member-card__bio">Режиссёр Евгений Баранов, Заслуженный артист России, актёр и режиссёр с многолетним стажем (театр им. Миронова, Санкт-Петербург), ставит эту историю без фальши и без скидок. Баранов — из той театральной школы, где актёр — не функция, а личность, где текст — не повод для кривляний, а материал для исследования человеческой души. За его плечами постановки «Нахлебник», «Грабёж», спектакли, в которых классика и современность встречаются на равных.</p>
              
              <div class="lt-member-card__awards">
                <h4 class="lt-awards-title">Заслуги и награды:</h4>
                <ul class="lt-awards-list">
                  <li>
                    <span class="lt-award-badge">1️⃣</span>
                    <span class="lt-award-text"><strong>Заслуженный артист РФ (1999)</strong></span>
                  </li>
                  <li>
                    <span class="lt-award-badge">2️⃣</span>
                    <span class="lt-award-text"><strong>«Золотой Софит» (1996)</strong> — высшая театральная премия Санкт-Петербурга — за лучшую мужскую роль в спектакле «Трудные люди»</span>
                  </li>
                  <li>
                    <span class="lt-award-badge">3️⃣</span>
                    <span class="lt-award-text"><strong>Актёрская премия «Фигаро» им. Андрея Миронова (2012)</strong> (номинация «Лучшие из лучших») — «За служение русскому репертуарному театру»</span>
                  </li>
                  <li>
                    <span class="lt-award-badge">4️⃣</span>
                    <span class="lt-award-text"><strong>Диплом III Всероссийского фестиваля «ON.ТЕАТР.ru» (2012)</strong> — «Лучшая мужская роль» за роль Сергея Довлатова в спектакле «Компромисс»</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Художник -->
          <div class="lt-member-card lt-member-card--designer">
            <div class="lt-member-card__photo-wrapper lt-member-card__photo-wrapper--graphic">
              <!-- Векторная маска / Иконка театрального платья/костюма -->
              <div class="lt-designer-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M12 2C10.9 2 10 2.9 10 4V5.1C7.2 5.6 5 8.1 5 11V18C5 19.1 5.9 20 7 20H8V22H10V20H14V22H16V20H17C18.1 20 19 19.1 19 18V11C19 8.1 16.8 5.6 14 5.1V4C14 2.9 13.1 2 12 2ZM12 7C14.2 7 16 8.8 16 11V12H8V11C8 8.8 9.8 7 12 7ZM7 14H17V18H7V14Z" fill="currentColor"/>
                </svg>
              </div>
            </div>
            <div class="lt-member-card__content">
              <span class="lt-member-card__role">Художник-постановщик</span>
              <h3 class="lt-member-card__name">Татьяна Королева</h3>
              <p class="lt-member-card__bio">Художник спектакля — Татьяна Королева, член Российского Авторского общества, является доцентом кафедры режиссуры музыкального театра Санкт-Петербургской Государственной Консерватории им. Н. А. Римского-Корсакова, лауреат премии Санкт-Петербурга за костюмы к спектаклю «Винил». Её сценографическое решение обещает быть не менее выразительным, чем драматургия: деталь, цвет, фактура — всё работает на образ и настроение.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- СЕКЦИЯ 5: В ролях (Actors / The Cast) -->
    <section class="lt-cast">
      <div class="container">
        <h2 class="lt-section-title text-center">В ролях</h2>
        
        <div class="lt-cast__grid">
          <!-- Елена Молодан -->
          <article class="lt-actor-card">
            <div class="lt-actor-card__img-wrapper">
              <img src="/assets/img/lubov_u_slivnogo_bochka/poetess_alone.jpg" alt="Елена Молодан" class="lt-actor-card__img" />
              <!-- Hover Overlay: Стихи -->
              <div class="lt-actor-card__overlay lt-actor-card__overlay--poetry">
                <div class="lt-poetry-bg">
                  <p>«Она нервная, с порога — на разрыв...»</p>
                  <p>«Привыкла говорить красиво...»</p>
                  <p>«...и любить со вкусом.»</p>
                </div>
              </div>
            </div>
            <div class="lt-actor-card__info">
              <h3 class="lt-actor-card__name">Елена Молодан</h3>
              <span class="lt-actor-card__role">Роль: Поэтесса</span>
              <p class="lt-actor-card__bio">Главную роль исполняет Елена Молодан — актриса с богатым театральным прошлым. Член Союза театральных деятелей России с 2000 года. Почти 20 лет она служила в Академическом Русском театре имени Евгения Вахтангова (Владикавказ), где сыграла множество разноплановых ролей. В петербургский период — участник независимого театрального проекта «Лестница» (спектакль «Война и мир. На-та-ша»), сотрудничество с Центром Михаила Чехова (режиссёр Елена Кузина), где ею сыграны Аркадина, леди Макбет, Мальволио, Ричард III и другие. В 2020–2021 годах прошла профессиональную переподготовку в ВШСИ — мастерская Константина Райкина. В 2121 году принимала участие в программе СТД. «Арт-резиденция Щелыково» со спектаклем «Укрощение своенравной» по пьесе У. Шекспира в переводе А.Н.Островского. Также с этим спектаклем принимала участие в открытии фестиваля «Лик» в Пушкинских горах. В 2024 году удостоена высшей награды за лучшую режиссуру на международном фестивале «Твой Шанс» (спектакль «Кошкин дом»).</p>
            </div>
          </article>

          <!-- Михаил Драгунов -->
          <article class="lt-actor-card">
            <div class="lt-actor-card__img-wrapper">
              <img src="/assets/img/lubov_u_slivnogo_bochka/plumber_alone.jpg" alt="Михаил Драгунов" class="lt-actor-card__img" />
              <!-- Hover Overlay: Чертежи -->
              <div class="lt-actor-card__overlay lt-actor-card__overlay--technical">
                <div class="lt-blueprint-bg">
                  <div class="blueprint-line blueprint-line--1"></div>
                  <div class="blueprint-line blueprint-line--2"></div>
                  <div class="lt-blueprint-text">
                    <p>«Он отвечает — не словами...»</p>
                    <p>«За грубостью — нежность...»</p>
                    <p>«...за молчанием — глубина.»</p>
                  </div>
                </div>
              </div>
            </div>
            <div class="lt-actor-card__info">
              <h3 class="lt-actor-card__name">Михаил Драгунов</h3>
              <span class="lt-actor-card__role">Роль: Сантехник</span>
              <p class="lt-actor-card__bio">Вторую главную роль исполняет Михаил Драгунов — актёр театра «Русская антреприза» имени Андрея Миронова (Санкт-Петербург). В театре им. Миронова с 2012 года. Среди его работ: Петя Трофимов («Вишнёвый сад»), Вронский в спектакле «Алексей Каренин» по пьесе Василия Сигарева, Леон («Мадам Бовари»), Дон Карлос и Сальери («Маленькие трагедии»), а также Фёдор в спектакле «Два часа в благородном семействе» режиссёра Евгения Баранова. С 2025 года сотрудничает с театром «Комедианты».</p>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- СЕКЦИЯ 6: Гастроли и Билеты (Tour & Booking Center) -->
    <section class="lt-booking">
      <div class="container">
        <div class="lt-booking__grid">
          
          <!-- Для организаторов и фестивалей -->
          <div class="lt-booking__organizers card-luxe">
            <h3 class="lt-booking__title">Организаторам и фестивалям</h3>
            <p class="lt-booking__desc">Спектакль полностью готов к гастролям и показам на любых профессиональных сценических площадках. Мы предоставляем полный гастрольный пакет.</p>
            
            <div class="lt-booking__downloads">
              <a href="#" class="btn btn-outline btn-download" onclick="alert('Технический райдер скачивается...'); return false;">
                <span class="btn-icon">📄</span> Скачать технический райдер (PDF)
              </a>
              <a href="#" class="btn btn-outline btn-download" onclick="alert('Бытовой райдер скачивается...'); return false;">
                <span class="btn-icon">📋</span> Скачать бытовой райдер (PDF)
              </a>
            </div>
            
            <div class="lt-booking__contacts">
              <p>По вопросам гастролей и показов:</p>
              <strong>Елена Анатольевна</strong>
              <a href="mailto:info@emozika.ru" class="lt-contact-link">info@emozika.ru</a>
              <a href="https://telegram.me/BurundukovS" target="_blank" class="lt-contact-link lt-contact-link--tg">Написать в Telegram</a>
            </div>
          </div>

          <!-- Для зрителей / Купить билет -->
          <div class="lt-booking__spectators card-luxe">
            <h3 class="lt-booking__title">Зрителям</h3>
            <blockquote class="lt-spectators-quote">
              «Зритель не уйдёт с лёгким сердцем. Он уйдёт с вопросом: "А что, если это и есть театр — когда ты выходишь из зала и понимаешь: это же про меня?"»
            </blockquote>
            
            <div class="lt-spectators-cta">
              <button class="btn btn-primary btn-lg btn-theatre-gold" data-yandex-ticket-event="example_event_love_tank">
                Купить билет
              </button>
            </div>
            
            <p class="lt-booking__pitch">«Любовь у сливного бачка». Приходи. Вдруг это — твоя история.</p>
          </div>

        </div>
      </div>
    </section>

  </main>
</Layout>
<script>
  // Скрипт для интерактивного появления карточек диалога при скролле и интерактивного манометра
  // 1. Анимации карточек диалога при скролле
  const rows = document.querySelectorAll('.scroll-reveal');
  
  const observerOptions = {
    root: null,
    threshold: 0.15,
    rootMargin: '0px 0px -10% 0px'
  };

  const observer = new IntersectionObserver((entries, observer) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  rows.forEach(row => {
    observer.observe(row);
  });

  // 2. Интерактивная станция манометра с вентилем
  const station = document.querySelector('.lt-hero__gauge-station');
  const valve = document.querySelector('.gauge-valve-wheel') as HTMLElement;
  const needle = document.querySelector('.gauge-needle') as HTMLElement;
  
  if (station && valve && needle) {
    let isSpinning = false;
    let twitchInterval: ReturnType<typeof setInterval>;
    let stateTimeout: ReturnType<typeof setTimeout>;

    let currentPressureState = 'green'; // 'green', 'yellow', 'red'
    let targetBaseAngle = -95;
    let currentBaseAngle = -95;

    // Плавная интерполяция стрелки к целевому углу
    const angleInterpInterval = setInterval(() => {
      if (isSpinning) return;
      const diff = targetBaseAngle - currentBaseAngle;
      if (Math.abs(diff) > 0.5) {
        currentBaseAngle += diff * 0.06;
      }
    }, 30);

    // Дрожание стрелки (вибрация зависит от давления)
    const startTwitch = () => {
      clearInterval(twitchInterval);
      twitchInterval = setInterval(() => {
        if (isSpinning) return;
        let offsetRange = 3;
        
        if (currentPressureState === 'yellow') {
          offsetRange = 6;
        } else if (currentPressureState === 'red') {
          offsetRange = 10; // Бешеное дрожание в красной зоне
        }
        
        const randomOffset = (Math.random() - 0.5) * offsetRange;
        needle.style.transform = `rotate(${currentBaseAngle + randomOffset}deg)`;
      }, 50);
    };

    startTwitch();

    // Последовательное нарастание давления (ускоренное в 2 раза)
    const runPressureCycle = () => {
      // 1. Зеленая зона (0-1.5 сек)
      currentPressureState = 'green';
      station.classList.add('state-green');
      station.classList.remove('state-yellow', 'state-red');
      targetBaseAngle = -95;
      
      // Стрелка начинает расти внутри зеленой зоны
      setTimeout(() => { if (!isSpinning) targetBaseAngle = -75; }, 300);

      // 2. Желтая зона (на 1.5 сек)
      stateTimeout = setTimeout(() => {
        if (isSpinning) return;
        currentPressureState = 'yellow';
        station.classList.add('state-yellow');
        station.classList.remove('state-green', 'state-red');
        targetBaseAngle = -5;
      }, 1500);

      // 3. Красная зона (на 3 сек)
      stateTimeout = setTimeout(() => {
        if (isSpinning) return;
        currentPressureState = 'red';
        station.classList.add('state-red');
        station.classList.remove('state-green', 'state-yellow');
        targetBaseAngle = 100;
      }, 3000);
    };

    runPressureCycle();

    // Реакция на наведение (дрожание возрастает)
    station.addEventListener('mouseenter', () => {
      if (isSpinning) return;
      clearInterval(twitchInterval);
      twitchInterval = setInterval(() => {
        if (isSpinning) return;
        const offset = currentPressureState === 'red' ? 14 : 9;
        const randomOffset = (Math.random() - 0.5) * offset;
        needle.style.transform = `rotate(${currentBaseAngle + randomOffset}deg)`;
      }, 30);
    });

    station.addEventListener('mouseleave', () => {
      if (isSpinning) return;
      startTwitch();
    });

    // Логика клика по вентилю (сброс давления и плавный скролл)
    const triggerRelease = () => {
      if (isSpinning) return;
      isSpinning = true;
      clearInterval(twitchInterval);
      clearTimeout(stateTimeout);

      // Включаем анимацию прокрутки вентиля и пара
      valve.classList.add('is-spinning');
      station.classList.add('is-releasing');

      // Стрелка делает оборот и падает на ноль (сброс давления)
      needle.style.transition = 'transform 0.6s cubic-bezier(0.25, 1, 0.5, 1)';
      needle.style.transform = `rotate(${currentBaseAngle + 360}deg)`;

      setTimeout(() => {
        needle.style.transition = 'transform 0.35s ease-out';
        needle.style.transform = 'rotate(-140deg)'; // Давление сброшено в ноль
      }, 300);

      // Плавный скролл вниз к повествованию через 500мс
      setTimeout(() => {
        const dialogueSec = document.querySelector('.lt-narrative');
        if (dialogueSec) {
          dialogueSec.scrollIntoView({ behavior: 'smooth' });
        }
      }, 500);

      // Рассеиваем пар и возвращаем прибор в строй спустя 1500мс
      setTimeout(() => {
        valve.classList.remove('is-spinning');
        station.classList.remove('is-releasing', 'state-yellow', 'state-red');
        station.classList.add('state-green');
        
        needle.style.transition = 'transform 1.2s ease-in-out';
        needle.style.transform = 'rotate(-95deg)';
        
        setTimeout(() => {
          isSpinning = false;
          currentPressureState = 'green';
          currentBaseAngle = -95;
          targetBaseAngle = -95;
          runPressureCycle(); // Перезапуск цикла нарастания
        }, 1200);
      }, 1500);
    };

    valve.addEventListener('click', triggerRelease);
    const dial = document.querySelector('.gauge-dial');
    if (dial) {
      dial.addEventListener('click', triggerRelease);
    }
  }
</script>
