---
import Layout from '../layouts/Layout.astro';
import HeroParticles from '../components/hub/HeroParticles.astro';
import NewsTicker from '../components/hub/NewsTicker.astro';
---

<Layout title="Театр-студия «Эмоцика» | Спектакли и обучение" description="Детский театр и киношкола в Санкт-Петербурге. Обучение актерскому мастерству, съемки в кино и спектакли для всей семьи.">
  <main id="main-content">
    <HeroParticles />
    <section class="hub-hero">
      <div class="container hub-hero__content">
        <h1 class="hub-hero__title">
            <span class="hub-hero__surtitle">Творческая экосистема</span>
            Театр. Студия. Кино.
        </h1>
        <p class="hub-hero__subtitle">
            Место, где дети находят друзей, побеждают страх сцены и снимаются в настоящем кино.
        </p>
      </div>
    </section>
    
    <NewsTicker />

    <section class="hub-nav">
        <div class="container hub-nav__grid">
            <!-- Studio -->
            <a href="/studio" class="hub-card hub-card--studio">
                <div class="hub-card__content">
                    <span class="hub-card__icon" aria-hidden="true">🎭</span>
                    <h2 class="hub-card__title">Я хочу учиться</h2>
                    <p class="hub-card__text">Театральная студия для детей 4-16 лет. 15 филиалов.</p>
                    <span class="hub-card__action">Выбрать группу →</span>
                </div>
            </a>

            <!-- Cinema -->
            <a href="/cinema" class="hub-card hub-card--cinema">
                <div class="hub-card__content">
                    <span class="hub-card__icon" aria-hidden="true">🎬</span>
                    <h2 class="hub-card__title">Я хочу в кино</h2>
                    <p class="hub-card__text">Кастинг-агентство и киношкола. Съемки и фестивали.</p>
                    <span class="hub-card__action">Пройти кастинг →</span>
                </div>
            </a>

            <!-- Theatre -->
            <a href="/theatre" class="hub-card hub-card--theatre">
                <div class="hub-card__content">
                    <span class="hub-card__icon" aria-hidden="true">🎟</span>
                    <h2 class="hub-card__title">Я зритель</h2>
                    <p class="hub-card__text">Афиша спектаклей и билеты в наш камерный театр.</p>
                    <span class="hub-card__action">Купить билет →</span>
                </div>
            </a>
        </div>
    </section>

    <section class="section section-map">
        <div class="container">
            <div class="section-header">
                <h2 class="section-title text-center">Мы рядом</h2>
                <p class="section-subtitle text-center">15 филиалов студии в разных районах + Сцена в «Гранд Каньоне»</p>
            </div>
            
            <figure class="hub-map-placeholder">
                <img src="/assets/img/branches-map.svg" alt="Карта филиалов театра-студии Эмоцика" class="img-responsive" loading="lazy" />
            </figure>
            
            <div class="hub-map-actions">
                 <a href="/studio#branches" class="btn btn-outline">Найти филиал у дома</a>
            </div>
        </div>
    </section>
  </main>
</Layout>

<style>
    /* Hub Hero */
    .hub-hero {
        position: relative;
        z-index: 1; /* Content above particles */
        padding: 6rem 0 4rem;
        background: transparent; /* Remove gradient, let particles shine or mix */
        /* keep subtle gradient if needed, but particles provide depth now */
        background: radial-gradient(circle at top right, rgba(162, 89, 255, 0.05), transparent 60%),
                    radial-gradient(circle at bottom left, rgba(64, 224, 208, 0.05), transparent 60%);
        text-align: center;
    }

    .hub-hero__content {
        max-width: 800px;
        margin: 0 auto;
    }

    .hub-hero__surtitle {
        display: block;
        font-family: var(--font-accent, sans-serif);
        font-size: 1.1rem;
        color: var(--color-primary, #A259FF);
        margin-bottom: 0.5rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .hub-hero__title {
        font-size: clamp(2rem, 5vw, 3.5rem);
        line-height: 1.1;
        font-weight: 700;
        margin-bottom: 1.5rem;
        color: var(--color-text-main, #333);
    }

    .hub-hero__subtitle {
        font-size: clamp(1.1rem, 2vw, 1.3rem);
        color: var(--color-text-muted, #666);
        line-height: 1.6;
    }

    /* Hub Nav Grid */
    .hub-nav {
        padding-bottom: 4rem;
    }

    .hub-nav__grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
    }

    .hub-card {
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: white;
        border-radius: 1.5rem;
        padding: 2.5rem;
        text-decoration: none;
        color: inherit;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        height: 100%;
        position: relative;
        overflow: hidden;
    }

    .hub-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(162, 89, 255, 0.15);
        border-color: rgba(162, 89, 255, 0.2);
    }

    .hub-card__icon {
        font-size: 3rem;
        margin-bottom: 1rem;
        display: block;
    }

    .hub-card__title {
        font-size: 1.75rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .hub-card__text {
        color: var(--color-text-muted, #666);
        margin-bottom: 1.5rem;
        line-height: 1.5;
    }

    .hub-card__action {
        font-weight: 600;
        color: var(--color-primary, #A259FF);
        margin-top: auto;
    }
    
    /* Specific card accents */
    .hub-card--studio:hover {
         border-top: 4px solid var(--color-primary, #A259FF);
    }
    .hub-card--cinema:hover {
         border-top: 4px solid #40E0D0; /* Turquoise */
    }
    .hub-card--theatre:hover {
         border-top: 4px solid #FF6B6B;
    }

    /* Map Section */
    .section-map {
        padding: 4rem 0;
        background-color: #FAFAFA;
    }
    
    .hub-map-placeholder {
        margin: 2rem auto;
        max-width: 800px;
        border-radius: 1rem;
        overflow: hidden;
    }
    
    .hub-map-actions {
        text-align: center;
        margin-top: 2rem;
    }
    
    @media (max-width: 768px) {
        .hub-hero { padding: 4rem 0 2rem; }
        .hub-nav__grid { grid-template-columns: 1fr; }
    }
</style>
